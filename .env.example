# Cloudflare Web Analytics (cookie-free, always on)
# Get your token from: Cloudflare Dashboard > Web Analytics > Add a site > smagile.co
PUBLIC_CF_ANALYTICS_TOKEN=

# Google Analytics (consent-gated, only loads after user opts in)
# Get your measurement ID from: Google Analytics > Admin > Data Streams
PUBLIC_GA_MEASUREMENT_ID=

# FreeAgent OAuth (for /admin/finance/ integration, read-only)
# Get credentials from: FreeAgent > Settings > Developer Dashboard > OAuth App
FREEAGENT_CLIENT_ID=your_oauth_identifier
FREEAGENT_CLIENT_SECRET=your_oauth_secret

# Supabase (for Mission Control metrics - Mosaic CV project)
# Get credentials from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
