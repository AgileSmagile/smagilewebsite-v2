---
import PublicLayout from '../layouts/PublicLayout.astro';
import ProductPartnerCard from '../components/ProductPartnerCard.astro';

const productPartners = [
  {
    name: 'Businessmap',
    tagline: 'Kanban-focused work management platform',
    description:
      'smagile uses Businessmap as the single source of truth for all delivery work. Portfolio-level visibility, WIP management, and flow metrics make it a powerful step up from basic task boards. Good for teams wanting to move beyond sticky notes to genuine flow-based delivery.',
    href: 'https://businessmap.io',
  },
  {
    name: 'Nave',
    tagline: 'Flow analytics and forecasting',
    description:
      'Probabilistic delivery forecasting, cycle time analysis, and throughput metrics. smagile uses Nave to bring data-driven decision making to delivery teams. Good for teams drowning in status meetings who want their data to speak for itself.',
    href: 'https://getnave.com',
  },
  {
    name: 'Actionable Agile',
    tagline: 'Flow metrics and analytics by Daniel Vacanti',
    description:
      'Monte Carlo simulation, ageing work item analysis, and cycle time scatterplots. The gold standard for Kanban analytics. Good for teams serious about using flow metrics to improve predictability.',
    href: 'https://actionableagile.com',
  },
  {
    name: 'SurveyMonkey',
    tagline: 'Survey and feedback platform',
    description:
      'smagile uses SurveyMonkey for retrospective surveys, team health checks, and training feedback. Good for gathering honest, anonymous feedback at scale.',
    href: 'https://www.surveymonkey.com',
  },
  {
    name: 'Capsule',
    tagline: 'Lightweight CRM',
    description:
      'smagile uses Capsule for contact management and pipeline tracking. Simple, affordable, and it does not try to be everything. Good for small businesses and consultancies who need CRM without the Salesforce overhead.',
    href: 'https://capsulecrm.com',
  },
  {
    name: 'Netlify',
    tagline: 'Web hosting and deployment platform',
    description:
      'Fast, developer-friendly, and excellent developer experience. Good for anyone deploying static sites or Jamstack applications.',
    href: 'https://www.netlify.com',
  },
  {
    name: 'Miro',
    tagline: 'Visual collaboration and whiteboarding',
    description:
      'smagile uses Miro for remote workshops, retrospectives, and collaborative planning. Good for distributed teams who need a shared visual space.',
    href: 'https://miro.com',
  },
  {
    name: 'Uptime Robot',
    tagline: 'Website monitoring',
    description:
      'Simple uptime checks with alerting. smagile uses it to monitor all its web properties. Good for anyone who needs to know when their site goes down before their customers tell them.',
    href: 'https://uptimerobot.com',
  },
];
---

<PublicLayout
  title="Partners"
  description="smagile Partner Network: specialist contractor introductions for UK insurers, and product partners we trust and recommend."
>
  <!-- Partner Network section -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <h1 class="text-3xl sm:text-4xl font-bold text-grey-900 dark:text-white">
      Partners
    </h1>
    <p class="mt-2 text-lg text-accent dark:text-accent-light font-medium">
      People and products we trust.
    </p>

    <!-- Jump links -->
    <div class="mt-6 flex flex-wrap gap-3 text-sm">
      <a
        href="#partner-network"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-secondary-100 dark:bg-grey-800 text-primary dark:text-secondary font-medium hover:bg-secondary-200 dark:hover:bg-grey-700 transition-colors"
      >
        Partner Network
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
      <a
        href="#product-partners"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-secondary-100 dark:bg-grey-800 text-primary dark:text-secondary font-medium hover:bg-secondary-200 dark:hover:bg-grey-700 transition-colors"
      >
        Product Partners
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Partner Network -->
  <section id="partner-network" class="relative bg-primary dark:bg-grey-800 py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/30 to-transparent"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-white font-heading">
        smagile Partner Network
      </h2>
      <div class="mt-4 w-16 h-px bg-gradient-to-r from-accent-light to-transparent"></div>
      <p class="mt-2 text-accent-light font-medium">
        Collaboration beats coordination.
      </p>

      <div class="mt-8 space-y-6 text-white/85 leading-relaxed">
        <p class="text-lg">
          smagile Partner Network is a specialist contractor introduction service focused
          exclusively on the UK insurance sector.
        </p>

        <p>
          We introduce a small, curated network of outside IR35 agile, product, and delivery
          contractors to insurers running complex change and transformation initiatives.
        </p>

        <p>
          The Partner Network exists to help UK insurers reduce delivery risk by introducing
          contractors we trust. These are people we have worked with directly on insurance
          and regulated change programmes, or would confidently hire ourselves.
        </p>

        <p>
          This is not recruitment and it is not volume based. We do not forward CVs or run
          keyword searches. We make targeted introductions based on real delivery capability
          and sector experience.
        </p>

        <div class="grid sm:grid-cols-2 gap-6 mt-8">
          <div>
            <h3 class="text-lg font-semibold text-white font-heading">What we do</h3>
            <ul class="mt-3 space-y-2 text-white/80">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-accent-light shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Outside IR35 contractor introductions only
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-accent-light shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Agile, product, and delivery specialists
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-accent-light shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                UK insurance experience required
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-accent-light shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Practitioner-led assessment
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white font-heading">What we do not do</h3>
            <ul class="mt-3 space-y-2 text-white/80">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-white/40 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Permanent recruitment
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-white/40 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Inside IR35 placements
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-white/40 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
                High volume agency recruitment
              </li>
            </ul>
          </div>
        </div>

        <h3 class="text-lg font-semibold text-white font-heading mt-8">Roles we cover</h3>
        <p>
          Ranging through strategy setting, design, delivery, and validation: UI/UX designers,
          developers, testers, architects, business and process analysts, Scrum Masters, Agile
          Coaches, Delivery Managers, Product Owners, Product Managers, and other senior
          delivery leaders.
        </p>

        <h3 class="text-lg font-semibold text-white font-heading mt-8">For contractors</h3>
        <p>
          If you are an independent agile, product, or delivery professional with UK insurance
          experience and our values resonate with you, we would love to hear from you.
        </p>
      </div>

      <div class="mt-10">
        <a
          href="/contact/"
          class="inline-block px-8 py-3.5 bg-white/10 hover:bg-white/20 text-white font-medium rounded-lg transition-all border border-white/20 hover:border-white/30"
        >
          Start a conversation
        </a>
      </div>
    </div>
  </section>

  <!-- Product Partners -->
  <section id="product-partners" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold text-grey-800 dark:text-white font-heading">
        Product Partners
      </h2>
      <div class="mt-4 mx-auto w-16 divider-gold"></div>
      <p class="mt-4 text-grey-700 dark:text-warm-200 max-w-2xl mx-auto leading-relaxed">
        Software tools smagile uses, recommends, or is partnered with. These are products
        we rely on in our own delivery work and client engagements.
      </p>
    </div>

    <div id="partner-carousel" class="relative">
      <!-- Carousel track -->
      <div class="overflow-hidden rounded-xl">
        <div id="carousel-track" class="flex transition-transform duration-500 ease-in-out">
          {productPartners.map((partner, i) => (
            <div class="carousel-slide w-full shrink-0 px-1" data-index={i}>
              <ProductPartnerCard
                name={partner.name}
                tagline={partner.tagline}
                description={partner.description}
                href={partner.href}
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation arrows -->
      <button
        id="carousel-prev"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 sm:-translate-x-5 w-10 h-10 flex items-center justify-center rounded-full bg-white dark:bg-grey-800 border border-secondary-200 dark:border-grey-600 shadow-lg text-primary dark:text-secondary hover:bg-secondary-50 dark:hover:bg-grey-700 transition-colors"
        aria-label="Previous partner"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="carousel-next"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 sm:translate-x-5 w-10 h-10 flex items-center justify-center rounded-full bg-white dark:bg-grey-800 border border-secondary-200 dark:border-grey-600 shadow-lg text-primary dark:text-secondary hover:bg-secondary-50 dark:hover:bg-grey-700 transition-colors"
        aria-label="Next partner"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Dots -->
      <div id="carousel-dots" class="flex justify-center gap-2 mt-6">
        {productPartners.map((_, i) => (
          <button
            class="carousel-dot w-2.5 h-2.5 rounded-full bg-secondary-200 dark:bg-grey-600 transition-colors"
            data-index={i}
            aria-label={`Go to partner ${i + 1}`}
          />
        ))}
      </div>
    </div>

    <script>
      (function () {
        const track = document.getElementById('carousel-track');
        const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        if (!track || !prevBtn || !nextBtn) return;

        const slides = track.querySelectorAll<HTMLDivElement>('.carousel-slide');
        const total = slides.length;
        if (total === 0) return;

        // Random start position
        let current = Math.floor(Math.random() * total);

        function goTo(index: number) {
          current = ((index % total) + total) % total;
          track.style.transform = `translateX(-${current * 100}%)`;
          dots.forEach((dot, i) => {
            dot.classList.toggle('bg-primary', i === current);
            dot.classList.toggle('dark:bg-secondary', i === current);
            dot.classList.toggle('bg-secondary-200', i !== current);
            dot.classList.toggle('dark:bg-grey-600', i !== current);
          });
        }

        prevBtn.addEventListener('click', () => goTo(current - 1));
        nextBtn.addEventListener('click', () => goTo(current + 1));
        dots.forEach((dot) => {
          dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
        });

        // Keyboard navigation
        document.getElementById('partner-carousel')?.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') goTo(current - 1);
          if (e.key === 'ArrowRight') goTo(current + 1);
        });

        // Touch swipe
        let touchStartX = 0;
        track.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
        track.addEventListener('touchend', (e) => {
          const diff = touchStartX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
        });

        // Initialise at random position
        goTo(current);
      })();
    </script>

    <!-- Affiliate disclosure -->
    <p class="mt-12 text-xs text-grey-500 dark:text-warm-300 text-center leading-relaxed">
      Some links on this page are affiliate links. If you sign up through them, smagile may
      earn a small commission at no extra cost to you.
    </p>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center px-4">
    <h2 class="text-2xl sm:text-3xl font-bold text-grey-800 dark:text-white font-heading">
      Want to partner with us?
    </h2>
    <div class="mt-4 mx-auto w-16 divider-gold"></div>
    <p class="mt-6 text-grey-700 dark:text-warm-300 max-w-xl mx-auto leading-relaxed">
      Whether you are a contractor, a software vendor, or a company looking for delivery talent,
      we would love to hear from you.
    </p>
    <div class="mt-8">
      <a
        href="/contact/"
        class="inline-block px-8 py-3.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-all shadow-lg shadow-primary/20 hover:shadow-primary/30 hover:-translate-y-0.5"
      >
        Get in touch
      </a>
    </div>
  </section>
</PublicLayout>
