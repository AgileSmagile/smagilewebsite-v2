---
import PublicLayout from '../../layouts/PublicLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const { Content } = await render(tool);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.data.name,
  description: tool.data.description,
  url: tool.data.websiteUrl,
  applicationCategory: tool.data.category,
  review: tool.data.recommendation
    ? {
        '@type': 'Review',
        author: {
          '@type': 'Organization',
          name: 'smagile',
          url: 'https://smagile.co',
        },
        reviewBody: tool.data.recommendation,
      }
    : undefined,
};
---

<PublicLayout
  title={`${tool.data.name} | Tools`}
  description={tool.data.description}
>
  <JsonLd data={jsonLd} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-grey-500 dark:text-warm-300">
        <li>
          <a href="/tools/" class="hover:text-primary dark:hover:text-secondary transition-colors">
            Tools
          </a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li class="text-grey-800 dark:text-white font-medium">{tool.data.name}</li>
      </ol>
    </nav>

    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-start gap-6">
      <div class="shrink-0 w-16 h-16 rounded-xl bg-secondary-100 dark:bg-grey-700 flex items-center justify-center overflow-hidden">
        {tool.data.logo ? (
          <img src={tool.data.logo} alt={`${tool.data.name} logo`} class="w-12 h-12 object-contain" />
        ) : (
          <span class="text-2xl font-bold text-primary dark:text-secondary font-heading">{tool.data.name.charAt(0)}</span>
        )}
      </div>
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-grey-900 dark:text-white font-heading">
          {tool.data.name}
        </h1>
        <div class="mt-2 flex flex-wrap items-center gap-3">
          <span class="text-sm px-3 py-1 rounded-full bg-secondary-100 dark:bg-grey-700 text-grey-700 dark:text-warm-200 capitalize">
            {tool.data.category}
          </span>
          {tool.data.featured && (
            <span class="text-sm px-3 py-1 rounded-full bg-accent/10 text-accent dark:text-accent-light font-medium">
              Featured
            </span>
          )}
        </div>
        <p class="mt-4 text-lg text-grey-700 dark:text-warm-200 leading-relaxed">
          {tool.data.description}
        </p>
      </div>
    </header>

    <!-- Key features -->
    {tool.data.keyFeatures.length > 0 && (
      <section class="mt-12">
        <h2 class="text-xl font-bold text-grey-800 dark:text-white font-heading">Key features</h2>
        <div class="mt-4 w-12 divider-gold"></div>
        <ul class="mt-6 grid gap-3 sm:grid-cols-2">
          {tool.data.keyFeatures.map((feature: string) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary dark:text-secondary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-grey-700 dark:text-warm-300">{feature}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- James's recommendation -->
    {tool.data.recommendation && (
      <section class="mt-12 p-6 sm:p-8 bg-secondary-50 dark:bg-grey-800 rounded-xl border border-secondary-200 dark:border-grey-700">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-primary dark:bg-secondary flex items-center justify-center">
            <span class="text-sm font-bold text-white dark:text-grey-900">JF</span>
          </div>
          <div>
            <p class="font-semibold text-grey-800 dark:text-white">James's take</p>
            <p class="text-xs text-grey-500 dark:text-warm-300">smagile founder</p>
          </div>
        </div>
        <p class="text-grey-700 dark:text-warm-300 leading-relaxed italic">
          {tool.data.recommendation}
        </p>
      </section>
    )}

    <!-- Long description (markdown body) -->
    <div class="mt-12 prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>

    <!-- Actions -->
    <div class="mt-12 flex flex-wrap gap-4">
      {tool.data.affiliateUrl ? (
        <a
          href={tool.data.affiliateUrl}
          rel="noopener sponsored"
          target="_blank"
          class="inline-block px-8 py-3.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-all shadow-lg shadow-primary/20 hover:shadow-primary/30 hover:-translate-y-0.5"
        >
          Try {tool.data.name}
        </a>
      ) : (
        <a
          href={tool.data.websiteUrl}
          rel="noopener"
          target="_blank"
          class="inline-block px-8 py-3.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-all shadow-lg shadow-primary/20 hover:shadow-primary/30 hover:-translate-y-0.5"
        >
          Visit {tool.data.name}
        </a>
      )}
      <a
        href="/tools/"
        class="inline-block px-8 py-3.5 bg-secondary-100 dark:bg-grey-700 hover:bg-secondary-200 dark:hover:bg-grey-600 text-primary dark:text-secondary font-medium rounded-lg transition-all"
      >
        View all tools
      </a>
    </div>

    <!-- Affiliate disclosure -->
    {tool.data.affiliateUrl && (
      <p class="mt-8 text-xs text-grey-500 dark:text-warm-300 leading-relaxed">
        This page contains an affiliate link. If you sign up through it, smagile may earn a small
        commission at no extra cost to you.
      </p>
    )}
  </article>
</PublicLayout>
