---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import { getCollection } from 'astro:content';

export const prerender = false;

// Load real blog content
const allPosts = await getCollection('blog');
const publishedPosts = allPosts.filter((p) => !p.data.draft);
const draftPosts = allPosts.filter((p) => p.data.draft);

// Current month stats
const now = new Date();
const currentMonth = now.getMonth();
const currentYear = now.getFullYear();
const publishedThisMonth = publishedPosts.filter((p) => {
  const d = p.data.pubDate;
  return d.getMonth() === currentMonth && d.getFullYear() === currentYear;
});

const monthLabel = now.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });

// Sort posts: drafts first, then by date descending
const sortedPosts = [...allPosts].sort((a, b) => {
  if (a.data.draft && !b.data.draft) return -1;
  if (!a.data.draft && b.data.draft) return 1;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

// Blog cadence: target is 2 per month (1 per fortnight)
const monthStart = new Date(currentYear, currentMonth, 1);
const monthEnd = new Date(currentYear, currentMonth + 1, 0);
const blogPublishedThisMonth = publishedThisMonth.length;
const blogTarget = 2;
---

<AdminLayout title="Content Pipeline">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Content' },
  ]} />

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white font-heading">Content Pipeline</h1>
    <p class="mt-1 text-sm text-warm-300">Publishing dashboard across all channels</p>
  </div>

  <!-- KPI row -->
  <div class="grid gap-4 grid-cols-2 lg:grid-cols-4 mb-8">
    <StatCard label="In Progress" value={draftPosts.length} subtitle="Draft blog posts" />
    <StatCard label="Scheduled" value={0} subtitle="No scheduling system yet" />
    <StatCard label="Published This Month" value={publishedThisMonth.length} subtitle={monthLabel} />
    <StatCard label="Total Published" value={publishedPosts.length} subtitle="All time, all channels" />
  </div>

  <!-- Content by channel -->
  <div class="mb-8">
    <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Content by Channel</h2>

    <div class="grid gap-4">
      <!-- Blog -->
      <div class="bg-grey-800 border border-grey-700 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-semibold text-white">Blog</h3>
          <span class="text-xs text-grey-500">{allPosts.length} {allPosts.length === 1 ? 'post' : 'posts'}</span>
        </div>

        {allPosts.length === 0 ? (
          <p class="text-sm text-grey-500 italic">No blog posts yet.</p>
        ) : (
          <div class="divide-y divide-grey-700">
            {sortedPosts.map((post) => (
              <div class="flex items-center justify-between py-3 first:pt-0 last:pb-0">
                <div class="flex items-center gap-3 min-w-0">
                  <a
                    href={post.data.draft ? undefined : `/resources/blog/${post.id}/`}
                    class:list={[
                      'text-sm truncate',
                      post.data.draft
                        ? 'text-warm-300'
                        : 'text-white hover:text-secondary transition-colors',
                    ]}
                  >
                    {post.data.title}
                  </a>
                </div>
                <div class="flex items-center gap-3 shrink-0 ml-4">
                  <span class:list={[
                    'inline-flex items-center px-2 py-0.5 rounded text-xs font-medium',
                    post.data.draft
                      ? 'bg-amber-500/20 text-amber-400'
                      : 'bg-green-500/20 text-green-400',
                  ]}>
                    {post.data.draft ? 'Draft' : 'Published'}
                  </span>
                  <span class="text-xs text-grey-500 w-20 text-right">
                    {post.data.pubDate.toLocaleDateString('en-GB', {
                      day: 'numeric',
                      month: 'short',
                      year: 'numeric',
                    })}
                  </span>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- LinkedIn -->
      <div class="bg-grey-800 border border-grey-700 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-semibold text-white">LinkedIn</h3>
          <span class="text-xs text-grey-500">0 posts</span>
        </div>

        <div class="text-center py-6">
          <p class="text-sm text-grey-500">No LinkedIn posts tracked yet.</p>
          <p class="mt-2 text-xs text-grey-600">Target: 2 posts per week</p>
        </div>
      </div>

      <!-- YouTube -->
      <div class="bg-grey-800 border border-grey-700 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-semibold text-white">YouTube</h3>
          <span class="text-xs text-grey-500">0 videos</span>
        </div>

        <div class="text-center py-6">
          <p class="text-sm text-grey-500">No YouTube content tracked yet.</p>
          <p class="mt-2 text-xs text-grey-600">Target: 1 video per month</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Publishing cadence targets -->
  <div class="mb-8">
    <div class="bg-grey-800 border border-grey-700 rounded-xl p-6">
      <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Publishing Cadence Targets</h2>

      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-white">LinkedIn</span>
          <div class="text-right">
            <span class="text-sm text-grey-500">0 this week</span>
            <span class="text-xs text-grey-600 ml-2">/ target 2 per week</span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-white">Blog</span>
          <div class="text-right">
            <span class="text-sm text-grey-500">{blogPublishedThisMonth} this month</span>
            <span class="text-xs text-grey-600 ml-2">/ target {blogTarget} per month</span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-white">YouTube</span>
          <div class="text-right">
            <span class="text-sm text-grey-500">0 this month</span>
            <span class="text-xs text-grey-600 ml-2">/ target 1 per month</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
