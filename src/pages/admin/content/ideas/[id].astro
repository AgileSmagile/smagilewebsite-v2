---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../../components/admin/Breadcrumb.astro';
import { getContentIdea } from '../../../../lib/admin/content-ideas';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/content/ideas');
}

const idea = await getContentIdea(id);

if (!idea) {
  return Astro.redirect('/admin/content/ideas');
}

const categoryOptions = [
  { value: 'social_media', label: 'Social Media' },
  { value: 'learning_catalogue', label: 'Learning Catalogue' },
];

const statusOptions = [
  { value: 'idea', label: 'Idea' },
  { value: 'drafted', label: 'Drafted' },
  { value: 'published', label: 'Published' },
  { value: 'archived', label: 'Archived' },
];
---

<AdminLayout title="Edit Idea">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Content', href: '/admin/content/' },
    { label: 'Ideas', href: '/admin/content/ideas/' },
    { label: 'Edit' },
  ]} />

  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white font-heading">Edit Idea</h1>
        <p class="mt-1 text-sm text-warm-300">
          Captured {new Date(idea.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' })}
        </p>
      </div>
      <a href="/admin/content/ideas/" class="text-sm text-secondary hover:text-white transition-colors">
        &larr; Back to Ideas
      </a>
    </div>
  </div>

  <form id="idea-form" class="space-y-6 max-w-3xl">
    <!-- Original capture -->
    <div>
      <label for="raw_input" class="block text-xs font-medium text-warm-300 uppercase tracking-wider mb-2">Original Idea</label>
      <textarea
        id="raw_input"
        name="raw_input"
        rows="3"
        class="w-full px-3 py-2 bg-grey-900 rounded-lg border border-grey-700 text-white text-sm leading-relaxed focus:border-secondary focus:outline-none resize-y"
        required
      >{idea.raw_input}</textarea>
    </div>

    <!-- Category and Status -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="category" class="block text-xs font-medium text-warm-300 uppercase tracking-wider mb-2">Category</label>
        <select
          id="category"
          name="category"
          class="w-full px-3 py-2 bg-grey-900 rounded-lg border border-grey-700 text-white text-sm focus:border-secondary focus:outline-none"
        >
          {categoryOptions.map((opt) => (
            <option value={opt.value} selected={idea.category === opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="status" class="block text-xs font-medium text-warm-300 uppercase tracking-wider mb-2">Status</label>
        <select
          id="status"
          name="status"
          class="w-full px-3 py-2 bg-grey-900 rounded-lg border border-grey-700 text-white text-sm focus:border-secondary focus:outline-none"
        >
          {statusOptions.map((opt) => (
            <option value={opt.value} selected={idea.status === opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Title -->
    <div>
      <label for="title" class="block text-xs font-medium text-warm-300 uppercase tracking-wider mb-2">
        Title <span class="text-grey-500 normal-case">(optional; add when the idea crystallises)</span>
      </label>
      <input
        type="text"
        id="title"
        name="title"
        value={idea.title || ''}
        class="w-full px-3 py-2 bg-grey-900 rounded-lg border border-grey-700 text-white text-sm focus:border-secondary focus:outline-none"
        placeholder="Working title for this content"
      />
    </div>

    <!-- Content -->
    <div>
      <label for="content" class="block text-xs font-medium text-warm-300 uppercase tracking-wider mb-2">
        Content <span class="text-grey-500 normal-case">(draft or generated text)</span>
      </label>
      <textarea
        id="content"
        name="content"
        rows="12"
        class="w-full px-3 py-2 bg-grey-900 rounded-lg border border-grey-700 text-white text-sm leading-relaxed focus:border-secondary focus:outline-none resize-y"
        placeholder="Write or paste content here..."
      >{idea.content || ''}</textarea>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3 pt-4 border-t border-grey-700">
      <button
        type="submit"
        id="save-btn"
        class="px-6 py-2 text-sm font-medium text-white bg-secondary rounded-lg hover:bg-secondary/80 transition-colors"
      >
        Save changes
      </button>
      <a
        href="/admin/content/ideas/"
        class="px-6 py-2 text-sm font-medium text-warm-300 bg-grey-700 rounded-lg border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
      >
        Cancel
      </a>
      <button
        type="button"
        id="delete-btn"
        class="ml-auto px-4 py-2 text-sm font-medium text-red-400 bg-grey-700 rounded-lg border border-grey-600 hover:bg-red-900/30 hover:border-red-500/30 transition-colors"
      >
        Delete idea
      </button>
    </div>
  </form>

  <!-- Status message -->
  <div id="status-msg" class="hidden mt-4 max-w-3xl px-4 py-2 rounded-lg text-sm"></div>
</AdminLayout>

<script define:vars={{ ideaId: idea.id }}>
  function showStatus(message, isError) {
    const el = document.getElementById('status-msg');
    if (!el) return;
    el.textContent = message;
    el.className = isError
      ? 'mt-4 max-w-3xl px-4 py-2 rounded-lg text-sm bg-red-900/30 text-red-400 border border-red-500/30'
      : 'mt-4 max-w-3xl px-4 py-2 rounded-lg text-sm bg-secondary/10 text-secondary border border-secondary/30';
  }

  // Form submission
  const form = document.getElementById('idea-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const saveBtn = document.getElementById('save-btn');
      if (saveBtn) {
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving...';
      }

      const payload = {
        raw_input: document.getElementById('raw_input')?.value?.trim(),
        category: document.getElementById('category')?.value,
        status: document.getElementById('status')?.value,
        title: document.getElementById('title')?.value?.trim() || null,
        content: document.getElementById('content')?.value || null,
      };

      if (!payload.raw_input) {
        showStatus('Original idea text is required.', true);
        document.getElementById('raw_input')?.focus();
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save changes';
        }
        return;
      }

      try {
        const res = await fetch(`/admin/api/content-ideas/${ideaId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Request failed' }));
          throw new Error(err.error || `HTTP ${res.status}`);
        }

        showStatus('Saved.', false);
      } catch (err) {
        console.error('Save failed:', err);
        showStatus(`Failed to save: ${err instanceof Error ? err.message : 'Unknown error'}`, true);
      } finally {
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save changes';
        }
      }
    });
  }

  // Delete button
  const deleteBtn = document.getElementById('delete-btn');
  if (deleteBtn) {
    deleteBtn.addEventListener('click', async () => {
      if (!confirm('Delete this idea? This cannot be undone.')) return;

      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Deleting...';

      try {
        const res = await fetch(`/admin/api/content-ideas/${ideaId}`, {
          method: 'DELETE',
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Request failed' }));
          throw new Error(err.error || `HTTP ${res.status}`);
        }

        window.location.href = '/admin/content/ideas/';
      } catch (err) {
        console.error('Delete failed:', err);
        deleteBtn.disabled = false;
        deleteBtn.textContent = 'Delete idea';
        showStatus(`Failed to delete: ${err instanceof Error ? err.message : 'Unknown error'}`, true);
      }
    });
  }
</script>
