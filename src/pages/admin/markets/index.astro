---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import { getAllMarketData } from '../../../lib/admin/markets';
import type { AssetPrice, PricePoint } from '../../../lib/admin/markets';

export const prerender = false;

const assets = await getAllMarketData();

const crypto = assets.filter((a) => a.category === 'crypto');
const forex = assets.filter((a) => a.category === 'forex');
const metals = assets.filter((a) => a.category === 'metal');

/** Format a price for display. */
function fmtPrice(asset: AssetPrice): string {
  if (asset.currentPrice === null) return 'N/A';
  const decimals = asset.category === 'metal' || asset.currentPrice >= 100 ? 0 : asset.currentPrice >= 1 ? 2 : 4;
  const prefix = asset.category === 'forex' ? '' : '\u00a3';
  return `${prefix}${asset.currentPrice.toLocaleString('en-GB', { minimumFractionDigits: decimals, maximumFractionDigits: decimals })}`;
}

/** Format 24h change. */
function fmtChange(change: number | null): string {
  if (change === null) return '';
  const sign = change >= 0 ? '+' : '';
  return `${sign}${change.toFixed(2)}%`;
}

/** Determine trend direction. */
function trend(change: number | null): 'up' | 'down' | 'flat' {
  if (change === null || Math.abs(change) < 0.01) return 'flat';
  return change > 0 ? 'up' : 'down';
}

/** Extract just the price values from a history array for sparkline. */
function sparklineData(points: PricePoint[]): number[] {
  if (points.length <= 1) return [];
  // Downsample to ~20 points for a compact sparkline
  const step = Math.max(1, Math.floor(points.length / 20));
  return points.filter((_, i) => i % step === 0).map((p) => p.price);
}

// Prepare JSON data for client-side chart rendering
const chartData = JSON.stringify(
  assets.map((a) => ({
    id: a.id,
    name: a.name,
    symbol: a.symbol,
    category: a.category,
    history24h: downsample(a.history24h, 50),
    history7d: downsample(a.history7d, 50),
    history30d: downsample(a.history30d, 50),
  })),
);

function downsample(points: PricePoint[], maxPoints: number): PricePoint[] {
  if (points.length <= maxPoints) return points;
  const step = Math.floor(points.length / maxPoints);
  return points.filter((_, i) => i % step === 0);
}
---

<AdminLayout title="Markets">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Markets' },
  ]} />

  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white font-heading">Markets</h1>
      <p class="mt-1 text-sm text-warm-300">Live and historical prices for crypto, forex, and precious metals</p>
    </div>
    <div class="flex items-center gap-2">
      <span id="last-updated" class="text-xs text-grey-500"></span>
      <button
        id="refresh-btn"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-white bg-primary hover:bg-primary-light rounded-lg transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Refresh
      </button>
    </div>
  </div>

  <!-- Time range selector -->
  <div class="mb-6 flex gap-1 p-1 bg-grey-800 rounded-lg w-fit border border-grey-700">
    <button data-range="24h" class="range-btn px-3 py-1.5 text-xs font-medium rounded-md bg-primary text-white transition-colors">24h</button>
    <button data-range="7d" class="range-btn px-3 py-1.5 text-xs font-medium rounded-md text-warm-300 hover:text-white transition-colors">7d</button>
    <button data-range="30d" class="range-btn px-3 py-1.5 text-xs font-medium rounded-md text-warm-300 hover:text-white transition-colors">30d</button>
  </div>

  <!-- Crypto section -->
  <section class="mb-8">
    <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Cryptocurrency</h2>
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2">
      {crypto.map((asset) => (
        <div class="p-5 bg-grey-800 rounded-xl border border-grey-700">
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="text-xs font-medium text-warm-300 uppercase tracking-wider">{asset.name}</p>
              <p class="text-xs text-grey-500">{asset.symbol}/GBP</p>
            </div>
            <div class="text-right">
              <p class="text-xl font-bold text-white font-heading">{fmtPrice(asset)}</p>
              {asset.change24h !== null && (
                <p class:list={[
                  'text-xs font-medium',
                  asset.change24h >= 0 ? 'text-green-400' : 'text-red-400',
                ]}>
                  {fmtChange(asset.change24h)} (24h)
                </p>
              )}
            </div>
          </div>
          <div class="chart-container" data-asset-id={asset.id}>
            <canvas class="w-full" height="80" style="max-height: 80px;"></canvas>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Forex section -->
  <section class="mb-8">
    <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Foreign Exchange</h2>
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-3">
      {forex.map((asset) => (
        <div class="p-5 bg-grey-800 rounded-xl border border-grey-700">
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="text-xs font-medium text-warm-300 uppercase tracking-wider">{asset.name}</p>
            </div>
            <div class="text-right">
              <p class="text-xl font-bold text-white font-heading">{fmtPrice(asset)}</p>
              {asset.change24h !== null && (
                <p class:list={[
                  'text-xs font-medium',
                  asset.change24h >= 0 ? 'text-green-400' : 'text-red-400',
                ]}>
                  {fmtChange(asset.change24h)} (24h)
                </p>
              )}
            </div>
          </div>
          <div class="chart-container" data-asset-id={asset.id}>
            <canvas class="w-full" height="80" style="max-height: 80px;"></canvas>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Metals section -->
  <section class="mb-8">
    <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Precious Metals</h2>
    <div class="mb-3 p-3 bg-yellow-900/20 border border-yellow-700/50 rounded-lg">
      <p class="text-xs text-yellow-300">
        Metal prices are placeholder values. A free metals API integration is pending.
      </p>
    </div>
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2">
      {metals.map((asset) => (
        <div class="p-5 bg-grey-800 rounded-xl border border-grey-700">
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="text-xs font-medium text-warm-300 uppercase tracking-wider">{asset.name}</p>
              <p class="text-xs text-grey-500">{asset.symbol}/GBP</p>
            </div>
            <div class="text-right">
              <p class="text-xl font-bold text-white font-heading">{fmtPrice(asset)}</p>
              <p class="text-xs text-grey-500">Placeholder</p>
            </div>
          </div>
          <div class="chart-container" data-asset-id={asset.id}>
            <canvas class="w-full" height="80" style="max-height: 80px;"></canvas>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Footer note -->
  <div class="p-4 bg-grey-800 rounded-xl border border-grey-700">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-secondary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-xs text-warm-300">
        Crypto data from CoinGecko. Forex rates from Frankfurter (ECB reference rates). Metal prices are placeholders.
        Prices auto-refresh every 60 seconds. All times in your local time zone.
      </p>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ chartData }}>
  // ---------------------------------------------------------------------------
  // Client-side: chart rendering and auto-refresh
  // ---------------------------------------------------------------------------

  const assets = JSON.parse(chartData);
  let currentRange = '24h';

  // Colour tokens
  const COLOURS = {
    line: '#75bcbe',
    fill: 'rgba(117, 188, 190, 0.1)',
    grid: 'rgba(74, 79, 79, 0.3)',
    text: '#B8AFA3',
  };

  /**
   * Draw a simple line chart on a canvas element.
   */
  function drawChart(canvas, points) {
    if (!points || points.length < 2) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);

    const w = rect.width;
    const h = rect.height;
    const pad = { top: 4, right: 4, bottom: 4, left: 4 };
    const plotW = w - pad.left - pad.right;
    const plotH = h - pad.top - pad.bottom;

    const prices = points.map(p => p.price);
    const min = Math.min(...prices);
    const max = Math.max(...prices);
    const range = max - min || 1;

    ctx.clearRect(0, 0, w, h);

    // Determine line colour based on trend
    const isUp = prices[prices.length - 1] >= prices[0];
    const lineColour = isUp ? '#4ade80' : '#f87171';
    const fillColour = isUp ? 'rgba(74, 222, 128, 0.08)' : 'rgba(248, 113, 113, 0.08)';

    // Draw filled area
    ctx.beginPath();
    points.forEach((p, i) => {
      const x = pad.left + (i / (points.length - 1)) * plotW;
      const y = pad.top + (1 - (p.price - min) / range) * plotH;
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.lineTo(pad.left + plotW, pad.top + plotH);
    ctx.lineTo(pad.left, pad.top + plotH);
    ctx.closePath();
    ctx.fillStyle = fillColour;
    ctx.fill();

    // Draw line
    ctx.beginPath();
    points.forEach((p, i) => {
      const x = pad.left + (i / (points.length - 1)) * plotW;
      const y = pad.top + (1 - (p.price - min) / range) * plotH;
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.strokeStyle = lineColour;
    ctx.lineWidth = 1.5;
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    ctx.stroke();

    // Draw current price dot
    const lastPoint = points[points.length - 1];
    const lastX = pad.left + plotW;
    const lastY = pad.top + (1 - (lastPoint.price - min) / range) * plotH;
    ctx.beginPath();
    ctx.arc(lastX, lastY, 3, 0, Math.PI * 2);
    ctx.fillStyle = lineColour;
    ctx.fill();
  }

  function getHistoryKey(range) {
    switch (range) {
      case '7d': return 'history7d';
      case '30d': return 'history30d';
      default: return 'history24h';
    }
  }

  function renderAllCharts() {
    const containers = document.querySelectorAll('.chart-container');
    containers.forEach(container => {
      const assetId = container.getAttribute('data-asset-id');
      const asset = assets.find(a => a.id === assetId);
      if (!asset) return;

      const canvas = container.querySelector('canvas');
      if (!canvas) return;

      const key = getHistoryKey(currentRange);
      drawChart(canvas, asset[key]);
    });
  }

  // Range buttons
  document.querySelectorAll('.range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentRange = btn.getAttribute('data-range') || '24h';

      // Update button styles
      document.querySelectorAll('.range-btn').forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('text-warm-300');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('text-warm-300');

      renderAllCharts();
    });
  });

  // Update timestamp
  function updateTimestamp() {
    const el = document.getElementById('last-updated');
    if (el) {
      el.textContent = 'Updated ' + new Date().toLocaleTimeString('en-GB', {
        hour: '2-digit',
        minute: '2-digit',
      });
    }
  }

  // Auto-refresh
  function startAutoRefresh() {
    setInterval(() => {
      window.location.reload();
    }, 60_000);
  }

  // Resize handler
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(renderAllCharts, 150);
  });

  // Refresh button
  document.getElementById('refresh-btn')?.addEventListener('click', () => {
    window.location.reload();
  });

  // Initialise
  renderAllCharts();
  updateTimestamp();
  startAutoRefresh();
</script>
