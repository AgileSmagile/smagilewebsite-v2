---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Course Management">
  <div class="flex items-center justify-between mb-8">
    <div>
      <div class="flex items-center gap-2 text-sm text-warm-300 mb-2">
        <a href="/admin/" class="hover:text-secondary transition-colors">Dashboard</a>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-white">Courses</span>
      </div>
      <h1 class="text-2xl font-bold text-white font-heading">Course Offerings</h1>
      <p class="mt-1 text-warm-300">Create and manage public training course listings.</p>
    </div>
    <button
      type="button"
      disabled
      class="px-4 py-2 bg-secondary/20 text-secondary/50 font-medium rounded-lg cursor-not-allowed text-sm"
    >
      + New Course
    </button>
  </div>

  <div class="bg-grey-800 rounded-xl border border-grey-700 overflow-hidden">
    <div class="px-6 py-4 border-b border-grey-700">
      <h2 class="text-sm font-medium text-warm-200">Current Courses</h2>
    </div>
    <div class="divide-y divide-grey-700">
      <div class="px-6 py-4 flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-white">Applying Professional Kanban (APK)</p>
          <p class="text-xs text-warm-300 mt-1">Licensed by ProKanban.org</p>
        </div>
        <span class="text-xs font-mono text-accent-light bg-accent/10 px-2 py-1 rounded">
          Published
        </span>
      </div>
      <div class="px-6 py-4 flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-white">Agile Fundamentals</p>
          <p class="text-xs text-warm-300 mt-1">Bespoke training for teams and leaders</p>
        </div>
        <span class="text-xs font-mono text-accent-light bg-accent/10 px-2 py-1 rounded">
          Published
        </span>
      </div>
    </div>
  </div>

  <div class="mt-8 p-6 border-2 border-dashed border-grey-700 rounded-xl text-center">
    <svg class="w-10 h-10 text-grey-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-3.03M11.42 15.17l5.1-3.03m-5.1 3.03V20.5m0 0l-5.1-3.03M11.42 20.5l5.1-3.03M6.32 12.14V5.81m0 0l5.1-3.03 5.1 3.03M6.32 5.81l5.1 3.03 5.1-3.03" />
    </svg>
    <p class="text-warm-300 text-sm">Course management tools are under development.</p>
    <p class="mt-2 text-xs text-grey-500">
      This area will allow you to create new course offerings, manage dates and pricing,
      and publish them directly to the public site.
    </p>
  </div>
</AdminLayout>
