---
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Dashboard">
  <h1 class="text-2xl font-bold text-white">Dashboard</h1>
  <p class="mt-2 text-grey-300">Welcome to the Smagile admin area.</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <a
      href="/admin/courses/"
      class="p-6 bg-grey-800 rounded-xl border border-grey-700 hover:border-secondary transition-colors"
    >
      <h2 class="text-lg font-semibold text-white">Course Offerings</h2>
      <p class="mt-2 text-sm text-grey-300">Create and manage training course listings.</p>
      <span class="mt-3 inline-block text-xs font-mono text-grey-300 bg-grey-700 px-2 py-1 rounded">
        Coming soon
      </span>
    </a>

    <div class="p-6 bg-grey-800 rounded-xl border border-grey-700 opacity-60">
      <h2 class="text-lg font-semibold text-white">Mission Control</h2>
      <p class="mt-2 text-sm text-grey-300">Personal command centre for tracking goals and projects.</p>
      <span class="mt-3 inline-block text-xs font-mono text-grey-300 bg-grey-700 px-2 py-1 rounded">
        Separate project
      </span>
    </div>

    <div class="p-6 bg-grey-800 rounded-xl border border-grey-700 opacity-60">
      <h2 class="text-lg font-semibold text-white">API Services</h2>
      <p class="mt-2 text-sm text-grey-300">Job trawler, CV generator, and other tools.</p>
      <span class="mt-3 inline-block text-xs font-mono text-grey-300 bg-grey-700 px-2 py-1 rounded">
        Separate project
      </span>
    </div>
  </div>
</AdminLayout>
