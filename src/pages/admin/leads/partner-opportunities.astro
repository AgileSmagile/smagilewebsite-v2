---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import EmptyState from '../../../components/admin/EmptyState.astro';
import { getPartnerOpportunities, type JobOpportunity } from '../../../lib/admin/opportunities';
import { getActivePartnersWithDetails, scorePartnerMatch, type PartnerProfile, type PartnerMatchResult } from '../../../lib/admin/partners';
import { formatRate, formatDate, scoreColour, scoreBg } from '../../../lib/admin/format';

export const prerender = false;

const selectedPartnerId = Astro.url.searchParams.get('partner') || 'all';

const [partners, opportunities] = await Promise.all([
  getActivePartnersWithDetails(),
  getPartnerOpportunities(),
]);

interface MatchedOpportunity extends JobOpportunity {
  partnerMatches: Array<{
    partner: PartnerProfile;
    match: PartnerMatchResult;
  }>;
  bestScore: number;
}

interface PartnerFilteredOpportunity extends MatchedOpportunity {
  selectedPartnerScore: number;
  selectedPartnerReasons: string[];
}

// Score every opportunity against every partner
const matchedOpportunities: MatchedOpportunity[] = opportunities.map((opp) => {
  const partnerMatches = partners
    .map((partner) => ({
      partner,
      match: scorePartnerMatch(partner, opp),
    }))
    .filter((pm) => pm.match.score > 0)
    .sort((a, b) => b.match.score - a.match.score);

  return {
    ...opp,
    partnerMatches,
    bestScore: partnerMatches.length > 0 ? partnerMatches[0].match.score : 0,
  };
});

// Filter by selected partner if applicable
const filteredOpportunities: (MatchedOpportunity | PartnerFilteredOpportunity)[] = selectedPartnerId === 'all'
  ? matchedOpportunities
    .filter((opp) => opp.partnerMatches.length > 0)
    .sort((a, b) => b.bestScore - a.bestScore)
  : matchedOpportunities
    .map((opp): PartnerFilteredOpportunity => {
      const pm = opp.partnerMatches.find((pm) => pm.partner.id === selectedPartnerId);
      return { ...opp, selectedPartnerScore: pm?.match.score ?? 0, selectedPartnerReasons: pm?.match.reasons ?? [] };
    })
    .filter((opp) => opp.selectedPartnerScore > 0)
    .sort((a, b) => b.selectedPartnerScore - a.selectedPartnerScore);

function isPartnerFiltered(opp: MatchedOpportunity | PartnerFilteredOpportunity): opp is PartnerFilteredOpportunity {
  return 'selectedPartnerScore' in opp;
}

function getPartnerScore(opp: MatchedOpportunity | PartnerFilteredOpportunity): number {
  return isPartnerFiltered(opp) ? opp.selectedPartnerScore : opp.bestScore;
}

function getPartnerReasons(opp: MatchedOpportunity | PartnerFilteredOpportunity): string[] {
  return isPartnerFiltered(opp) ? opp.selectedPartnerReasons : (opp.partnerMatches[0]?.match.reasons || []);
}

// KPIs
const activePartnerCount = partners.length;
const outsideIR35Count = opportunities.length;
const highMatchCount = matchedOpportunities.filter((opp) => opp.bestScore >= 60).length;

const selectedPartner = selectedPartnerId !== 'all'
  ? partners.find((p) => p.id === selectedPartnerId)
  : null;
---

<AdminLayout title="Partner Network Opportunities">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Leads', href: '/admin/leads/' },
    { label: 'Partner Opportunities' },
  ]} />

  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white font-heading">Partner Network Opportunities</h1>
        <p class="mt-1 text-sm text-warm-300">Outside IR35 roles matched to your partner network</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/admin/leads/opportunities" class="px-3 py-1.5 text-sm font-medium text-secondary bg-secondary/10 rounded-lg border border-secondary/30 hover:bg-secondary/20 transition-colors">
          Your Opportunities
        </a>
        <a href="/admin/leads/" class="text-sm text-secondary hover:text-white transition-colors">
          &larr; Back to Leads
        </a>
      </div>
    </div>
  </div>

  <!-- KPI row -->
  <div class="grid gap-4 grid-cols-2 lg:grid-cols-3 mb-8">
    <StatCard label="Active Partners" value={String(activePartnerCount)} subtitle="Synced from Capsule CRM" />
    <StatCard label="Outside IR35 Roles" value={String(outsideIR35Count)} subtitle="Currently active" />
    <StatCard label="High Matches" value={String(highMatchCount)} subtitle="60%+ match for any partner" trend={highMatchCount > 0 ? 'up' : undefined} />
  </div>

  {partners.length === 0 ? (
    <EmptyState
      heading="No partner profiles synced yet"
      message="Add partners in Capsule CRM and run the sync script."
      iconPath="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
    />
  ) : opportunities.length === 0 ? (
    <EmptyState
      heading="No outside IR35 opportunities found"
      message="Opportunities are refreshed twice daily."
      iconPath="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0"
    />
  ) : (
    <>
      <!-- Partner selector -->
      <div class="bg-grey-800 rounded-xl border border-grey-700 p-4 mb-6">
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-xs font-medium text-warm-300 uppercase tracking-wider">Partner:</span>
          <div class="flex gap-1 flex-wrap">
            <a
              href="/admin/leads/partner-opportunities"
              class:list={[
                'px-2.5 py-1 text-xs rounded-lg border transition-colors',
                selectedPartnerId === 'all'
                  ? 'bg-secondary/20 border-secondary text-secondary'
                  : 'bg-grey-900 border-grey-700 text-warm-300 hover:border-grey-600',
              ]}
            >
              All Partners
            </a>
            {partners.map((p) => (
              <a
                href={`/admin/leads/partner-opportunities?partner=${p.id}`}
                class:list={[
                  'px-2.5 py-1 text-xs rounded-lg border transition-colors',
                  selectedPartnerId === p.id
                    ? 'bg-secondary/20 border-secondary text-secondary'
                    : 'bg-grey-900 border-grey-700 text-warm-300 hover:border-grey-600',
                ]}
              >
                {p.name}
              </a>
            ))}
          </div>
          <span class="ml-auto text-xs text-grey-500">
            {filteredOpportunities.length} {filteredOpportunities.length === 1 ? 'match' : 'matches'}
          </span>
        </div>
      </div>

      {selectedPartner && (
        <div class="mb-6 p-3 rounded-lg bg-primary/10 border border-primary/30">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-sm">
              {selectedPartner.name.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-medium text-white">{selectedPartner.name}</p>
              <p class="text-xs text-grey-500">
                {(selectedPartner.role_titles || []).join(' / ') || 'No role titles set'}
                {selectedPartner.day_rate_min ? ` · From £${selectedPartner.day_rate_min}/day` : ''}
                {selectedPartner.availability ? ` · ${selectedPartner.availability}` : ''}
              </p>
            </div>
          </div>
        </div>
      )}

      {filteredOpportunities.length === 0 ? (
        <EmptyState
          heading="No strong matches found"
          message={selectedPartner
            ? `${selectedPartner.name}'s profile did not match any current opportunities. Their profile may need more skills or role titles.`
            : 'Partner profiles may need more skills or role titles to match against current opportunities.'}
          iconPath="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
        />
      ) : (
        <div class="bg-grey-800 rounded-xl border border-grey-700 p-6">
          <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
              <thead>
                <tr class="border-b border-grey-700">
                  <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Match</th>
                  <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Role</th>
                  <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Rate</th>
                  <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Agency</th>
                  <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Location</th>
                  <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Posted</th>
                  {selectedPartnerId === 'all' && (
                    <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden sm:table-cell">Partners</th>
                  )}
                  <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody>
                {filteredOpportunities.map((opp) => {
                  const displayScore = getPartnerScore(opp);
                  const displayReasons = getPartnerReasons(opp);
                  return (
                    <tr class="border-b border-grey-700/50 last:border-0 group">
                      <td class="py-3">
                        <span class:list={['inline-flex items-center justify-center w-10 h-6 rounded text-xs font-bold', scoreBg(displayScore), scoreColour(displayScore)]}>
                          {displayScore}%
                        </span>
                      </td>
                      <td class="py-3">
                        <div>
                          <a href={opp.url} target="_blank" rel="noopener" class="text-white font-medium hover:text-secondary transition-colors">
                            {opp.title.length > 55 ? opp.title.slice(0, 55) + '...' : opp.title}
                          </a>
                          {displayReasons.length > 0 && (
                            <p class="text-xs text-grey-500 mt-0.5">{displayReasons.join(' · ')}</p>
                          )}
                        </div>
                      </td>
                      <td class="py-3 text-warm-300 hidden md:table-cell">{formatRate(opp.day_rate_min, opp.day_rate_max)}</td>
                      <td class="py-3 text-warm-300 hidden lg:table-cell">{opp.agency || '-'}</td>
                      <td class="py-3 text-warm-300 hidden lg:table-cell">{(opp.location || '-').length > 20 ? opp.location!.slice(0, 20) + '...' : opp.location || '-'}</td>
                      <td class="py-3 text-grey-500 hidden md:table-cell">{formatDate(opp.date_posted)}</td>
                      {selectedPartnerId === 'all' && (
                        <td class="py-3 hidden sm:table-cell">
                          <div class="flex flex-wrap gap-1">
                            {opp.partnerMatches.slice(0, 3).map((pm) => (
                              <a
                                href={`/admin/leads/partner-opportunities?partner=${pm.partner.id}`}
                                class="inline-flex items-center gap-1 px-1.5 py-0.5 text-xs rounded bg-grey-700/50 text-warm-300 hover:text-white transition-colors"
                              >
                                <span class:list={['w-1.5 h-1.5 rounded-full', pm.match.score >= 60 ? 'bg-green-400' : pm.match.score >= 30 ? 'bg-amber-400' : 'bg-grey-500']}></span>
                                {pm.partner.name.split(' ')[0]}
                              </a>
                            ))}
                            {opp.partnerMatches.length > 3 && (
                              <span class="text-xs text-grey-500">+{opp.partnerMatches.length - 3}</span>
                            )}
                          </div>
                        </td>
                      )}
                      <td class="py-3">
                        <a
                          href={opp.url}
                          target="_blank"
                          rel="noopener"
                          class="px-3 py-1 text-xs font-medium text-warm-300 bg-grey-700 rounded border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
                        >
                          View
                        </a>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <!-- High matches detail section -->
      {filteredOpportunities.filter((o) => getPartnerScore(o) >= 60).length > 0 && (
        <div class="mt-6 bg-grey-800 rounded-xl border border-grey-700 p-6">
          <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Top Matches</h2>
          <div class="space-y-3">
            {filteredOpportunities
              .filter((o) => getPartnerScore(o) >= 60)
              .map((opp) => {
                const displayScore = getPartnerScore(opp);
                const displayReasons = getPartnerReasons(opp);
                return (
                  <div class="p-3 bg-grey-900/50 rounded-lg border border-grey-700/50">
                    <div class="flex items-center justify-between mb-1">
                      <a href={opp.url} target="_blank" rel="noopener" class="text-sm font-medium text-white hover:text-secondary">
                        {opp.title}
                      </a>
                      <span class="text-sm font-bold text-green-400">{displayScore}%</span>
                    </div>
                    <p class="text-xs text-grey-500">
                      {formatRate(opp.day_rate_min, opp.day_rate_max)} · {opp.agency || 'Agency not stated'} · {opp.location || 'Location not stated'}
                    </p>
                    {displayReasons.length > 0 && (
                      <p class="text-xs text-warm-300 mt-1">{displayReasons.join(' · ')}</p>
                    )}
                    {selectedPartnerId === 'all' && opp.partnerMatches.length > 0 && (
                      <div class="flex flex-wrap gap-1 mt-2">
                        {opp.partnerMatches.map((pm) => (
                          <span class="inline-flex items-center gap-1 px-1.5 py-0.5 text-xs rounded bg-grey-700/50 text-warm-300">
                            <span class:list={['w-1.5 h-1.5 rounded-full', pm.match.score >= 60 ? 'bg-green-400' : pm.match.score >= 30 ? 'bg-amber-400' : 'bg-grey-500']}></span>
                            {pm.partner.name} ({pm.match.score}%)
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                );
              })}
          </div>
        </div>
      )}
    </>
  )}

  <p class="text-xs text-grey-500 text-center mt-6">
    Data sourced from Reed.co.uk and Adzuna. Refreshed twice daily. Matching is based on role titles, skills, and day rates.
  </p>
</AdminLayout>
