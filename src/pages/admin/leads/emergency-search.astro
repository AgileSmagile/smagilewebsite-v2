---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import OpportunityStatusScript from '../../../components/admin/OpportunityStatusScript.astro';
import { getEmergencyOpportunities, type OpportunitySummary } from '../../../lib/admin/opportunities';
import { getProfileByEmail, scoreOpportunity, type ProfileMatchResult } from '../../../lib/admin/profile-matching';
import { formatRate, formatDate, scoreColour, scoreBg } from '../../../lib/admin/format';
import { buildFilterUrl } from '../../../lib/admin/filter-url';

export const prerender = false;

// Read filter params
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const recencyParam = Astro.url.searchParams.get('recency') || '7';
const recencyDays = recencyParam === 'all' ? undefined : (Number.isNaN(parseInt(recencyParam, 10)) ? 7 : parseInt(recencyParam, 10));

// Fetch all emergency opportunities for this recency window (no status filter),
// derive summary counts in memory, then apply the status filter in JS.
const allEmergencyOpps = await getEmergencyOpportunities('all', recencyDays);

const summary: OpportunitySummary = { total: allEmergencyOpps.length, new: 0, seen: 0, applied: 0, highMatch: 0 };
for (const opp of allEmergencyOpps) {
  if (opp.status === 'new') summary.new++;
  else if (opp.status === 'seen') summary.seen++;
  else if (opp.status === 'applied') summary.applied++;
  if ((opp.match_score ?? 0) >= 60) summary.highMatch++;
}

const opportunities = statusFilter === 'all'
  ? allEmergencyOpps
  : allEmergencyOpps.filter((o) => o.status === statusFilter);

// Fetch user's Mosaic CV profile for matching
const cfEmail = Astro.request.headers.get('Cf-Access-Authenticated-User-Email');
const ownerEmail = process.env.OWNER_EMAIL;
const profileEmail = cfEmail || ownerEmail || '';
const profile = profileEmail ? await getProfileByEmail(profileEmail) : null;

// Score each opportunity against the profile
type ScoredOpportunity = typeof opportunities[number] & {
  profileMatch?: ProfileMatchResult;
};

const scoredOpportunities: ScoredOpportunity[] = opportunities.map((opp) => {
  if (!profile) return opp;
  const match = scoreOpportunity(profile, opp.title, opp.description_snippet);
  return { ...opp, profileMatch: match };
});

// Re-sort by profile match score when available, falling back to trawler score
// Then demote applied/seen roles to the bottom
scoredOpportunities.sort((a, b) => {
  const aDemoted = a.status === 'applied' || a.status === 'seen';
  const bDemoted = b.status === 'applied' || b.status === 'seen';
  if (aDemoted !== bDemoted) return aDemoted ? 1 : -1;

  const scoreA = a.profileMatch?.score ?? a.match_score ?? 0;
  const scoreB = b.profileMatch?.score ?? b.match_score ?? 0;
  return scoreB - scoreA;
});

// Update summary highMatch count based on profile matching
const highMatchCount = profile
  ? scoredOpportunities.filter((o) => (o.profileMatch?.score ?? 0) >= 60).length
  : summary.highMatch;

function getDisplayScore(opp: ScoredOpportunity): number {
  return opp.profileMatch?.score ?? opp.match_score ?? 0;
}

const statusFilters = [
  { value: 'all', label: 'All', count: summary.total },
  { value: 'new', label: 'New', count: summary.new },
  { value: 'seen', label: 'Seen', count: summary.seen },
  { value: 'applied', label: 'Applied', count: summary.applied },
];

const recencyOptions = [
  { value: '0', label: 'Today' },
  { value: '1', label: 'Past 24hrs' },
  { value: '3', label: 'Past 3 days' },
  { value: '7', label: 'Past 7 days' },
  { value: 'all', label: 'All open' },
];

const emergencyDefaults: Record<string, string> = { status: 'all', recency: '7' };
const emergencyParams: Record<string, string> = { status: statusFilter, recency: recencyParam };

function buildUrl(params: Record<string, string>): string {
  return buildFilterUrl('/admin/leads/emergency-search', emergencyParams, emergencyDefaults, params);
}
---

<AdminLayout title="Emergency Job Search">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Leads', href: '/admin/leads/' },
    { label: 'Opportunities', href: '/admin/leads/opportunities' },
    { label: 'Emergency Search' },
  ]} />

  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white font-heading">Emergency Job Search</h1>
        <p class="mt-1 text-sm text-warm-300">Perm and inside IR35 roles matched to your Mosaic CV profile</p>
      </div>
      <a href="/admin/leads/opportunities" class="text-sm text-secondary hover:text-white transition-colors">
        &larr; Outside IR35 roles
      </a>
    </div>
  </div>

  <!-- Info banner -->
  {profile ? (
    <div class="mb-6 p-3 rounded-lg bg-secondary/10 border border-secondary/30">
      <p class="text-sm text-secondary">
        Matching against your Mosaic CV profile. Scores reflect skill and role overlap with each listing.
      </p>
    </div>
  ) : (
    <div class="mb-6 p-3 rounded-lg bg-grey-800 border border-grey-700">
      <p class="text-sm text-warm-300">
        Scores are based on the job trawler's keyword matching. Connect your Mosaic CV profile for personalised skill and role matching.
      </p>
    </div>
  )}

  <!-- KPI row -->
  <div class="grid gap-4 grid-cols-2 lg:grid-cols-4 mb-8">
    <StatCard label="Total Active" value={String(summary.total)} subtitle={recencyDays === undefined ? 'All open' : recencyDays === 0 ? 'Today' : `Last ${recencyDays} days`} />
    <StatCard label="New" value={String(summary.new)} subtitle="Not yet reviewed" />
    <StatCard label="High Match" value={String(highMatchCount)} subtitle="60%+ compatibility" trend={highMatchCount > 0 ? 'up' : undefined} />
    <StatCard label="Applied" value={String(summary.applied)} subtitle="In your pipeline" />
  </div>

  <!-- Filters row -->
  <div class="flex flex-wrap items-center gap-4 mb-6">
    <!-- Status filters -->
    <div class="flex gap-2">
      {statusFilters.map((f) => (
        <a
          href={buildUrl({ status: f.value })}
          class:list={[
            'px-3 py-1.5 text-sm rounded-lg border transition-colors',
            statusFilter === f.value
              ? 'bg-secondary/20 border-secondary text-secondary'
              : 'bg-grey-800 border-grey-700 text-warm-300 hover:border-grey-600',
          ]}
        >
          {f.label} <span class="text-xs opacity-60">({f.count})</span>
        </a>
      ))}
    </div>

    <!-- Recency filter -->
    <div class="flex items-center gap-2 ml-auto">
      <span class="text-xs text-warm-300 uppercase tracking-wider">Posted within</span>
      <div class="flex gap-1">
        {recencyOptions.map((r) => (
          <a
            href={buildUrl({ recency: r.value })}
            class:list={[
              'px-2 py-1 text-xs rounded border transition-colors',
              recencyParam === r.value
                ? 'bg-secondary/20 border-secondary text-secondary'
                : 'bg-grey-800 border-grey-700 text-warm-300 hover:border-grey-600',
            ]}
          >
            {r.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Opportunities table -->
  <div class="bg-grey-800 rounded-xl border border-grey-700 p-6">
    {scoredOpportunities.length === 0 ? (
      <p class="text-sm text-grey-500 text-center py-8">No opportunities found for this filter.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="border-b border-grey-700">
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Match</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Role</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Rate</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Agency</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Location</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden sm:table-cell">IR35</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Posted</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody>
            {scoredOpportunities.map((opp) => {
              const displayScore = getDisplayScore(opp);
              return (
                <tr
                  class:list={[
                    'border-b border-grey-700/50 last:border-0',
                    opp.status === 'applied' && 'opacity-50',
                  ]}
                  data-opp-row={opp.id}
                >
                  <td class="py-3">
                    <span
                      class:list={['inline-flex items-center justify-center w-10 h-6 rounded text-xs font-bold', scoreBg(displayScore), scoreColour(displayScore)]}
                      title={opp.profileMatch?.reasoning || ''}
                    >
                      {displayScore}%
                    </span>
                  </td>
                  <td class="py-3">
                    <a href={opp.url} target="_blank" rel="noopener" class="text-white font-medium hover:text-secondary transition-colors">
                      {opp.title.length > 50 ? opp.title.slice(0, 50) + '...' : opp.title}
                    </a>
                    {opp.status === 'new' && (
                      <span class="ml-2 inline-block w-2 h-2 rounded-full bg-blue-400" title="New"></span>
                    )}
                    {opp.profileMatch && (opp.profileMatch.directMatches.length > 0 || opp.profileMatch.adjacentMatches.length > 0) && (
                      <div class="mt-1 flex flex-wrap gap-1">
                        {opp.profileMatch.directMatches.slice(0, 3).map((m) => (
                          <span class="inline-block px-1.5 py-0.5 rounded text-[10px] bg-green-500/15 text-green-400 border border-green-500/20">
                            {m}
                          </span>
                        ))}
                        {opp.profileMatch.adjacentMatches.slice(0, 2).map((m) => (
                          <span class="inline-block px-1.5 py-0.5 rounded text-[10px] bg-amber-500/15 text-amber-400 border border-amber-500/20">
                            {m.length > 30 ? m.slice(0, 30) + '...' : m}
                          </span>
                        ))}
                      </div>
                    )}
                  </td>
                  <td class="py-3 text-warm-300 hidden md:table-cell">{formatRate(opp.day_rate_min, opp.day_rate_max)}</td>
                  <td class="py-3 text-warm-300 hidden lg:table-cell">{opp.agency || '-'}</td>
                  <td class="py-3 text-warm-300 hidden lg:table-cell">{opp.location || '-'}</td>
                  <td class="py-3 hidden sm:table-cell">
                    <span class:list={[
                      'inline-block px-2 py-0.5 rounded-full text-xs font-medium',
                      opp.ir35_status === 'inside' ? 'bg-amber-500/20 text-amber-400' : 'bg-grey-700/30 text-grey-500',
                    ]}>
                      {opp.ir35_status}
                    </span>
                  </td>
                  <td class="py-3 text-grey-500 hidden md:table-cell">{formatDate(opp.date_posted)}</td>
                  <td class="py-3">
                    <div class="flex items-center gap-2">
                      <a
                        href={opp.url}
                        target="_blank"
                        rel="noopener"
                        class="px-3 py-1 text-xs font-medium text-warm-300 bg-grey-700 rounded border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
                      >
                        View
                      </a>
                      {opp.status === 'applied' ? (
                        <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-secondary/20 text-secondary">Applied</span>
                      ) : (
                        <>
                          {opp.status === 'new' && (
                            <button
                              data-opp-id={opp.id}
                              data-action="seen"
                              class="opp-status-btn px-3 py-1 text-xs font-medium text-warm-300 bg-grey-700 rounded border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
                            >
                              Mark Seen
                            </button>
                          )}
                          <button
                            data-opp-id={opp.id}
                            data-action="applied"
                            class="opp-status-btn px-3 py-1 text-xs font-medium text-grey-900 bg-secondary rounded border border-secondary hover:bg-secondary/80 transition-colors"
                          >
                            Applied
                          </button>
                          <button
                            data-opp-id={opp.id}
                            data-action="removed"
                            class="opp-remove-btn px-2 py-1 text-xs font-medium text-red-400/70 bg-grey-800 rounded border border-grey-700 hover:bg-red-500/10 hover:border-red-500/30 hover:text-red-400 transition-colors"
                            title="Remove from results"
                          >
                            &times;
                          </button>
                        </>
                      )}
                      {opp.businessmap_card_id && (
                        <a
                          href={`https://smagile.kanbanize.com/ctrl_board/5/cards/${opp.businessmap_card_id}/details`}
                          target="_blank"
                          rel="noopener"
                          class="px-2 py-0.5 text-xs font-medium rounded bg-blue-500/20 text-blue-400 hover:text-blue-300 transition-colors"
                          title="View on Businessmap"
                        >
                          #{opp.businessmap_card_id}
                        </a>
                      )}
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Match reasons detail for top matches -->
  {scoredOpportunities.filter(o => getDisplayScore(o) >= 60).length > 0 && (
    <div class="mt-6 bg-grey-800 rounded-xl border border-grey-700 p-6">
      <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Top Matches</h2>
      <div class="space-y-3">
        {scoredOpportunities.filter(o => getDisplayScore(o) >= 60).map((opp) => (
          <div class="p-3 bg-grey-900/50 rounded-lg border border-grey-700/50">
            <div class="flex items-center justify-between mb-1">
              <a href={opp.url} target="_blank" rel="noopener" class="text-sm font-medium text-white hover:text-secondary">
                {opp.title}
              </a>
              <span class="text-sm font-bold text-green-400">{getDisplayScore(opp)}%</span>
            </div>
            <p class="text-xs text-grey-500">
              {formatRate(opp.day_rate_min, opp.day_rate_max)} · {opp.agency || 'Agency not stated'} · {opp.location || 'Location not stated'}
            </p>
            {opp.profileMatch ? (
              <div class="mt-2 space-y-1">
                {opp.profileMatch.directMatches.length > 0 && (
                  <p class="text-xs text-green-400">
                    <span class="font-medium">Direct:</span> {opp.profileMatch.directMatches.join(', ')}
                  </p>
                )}
                {opp.profileMatch.adjacentMatches.length > 0 && (
                  <p class="text-xs text-amber-400">
                    <span class="font-medium">Adjacent:</span> {opp.profileMatch.adjacentMatches.join(', ')}
                  </p>
                )}
              </div>
            ) : opp.match_reasons ? (
              <p class="text-xs text-warm-300 mt-1">{opp.match_reasons.join(' · ')}</p>
            ) : null}
          </div>
        ))}
      </div>
    </div>
  )}

  <p class="text-xs text-grey-500 text-center mt-6">
    Data sourced from Reed.co.uk. Refreshed twice daily.
    {recencyDays === undefined ? ' Showing all open listings.' : recencyDays === 0 ? ' Showing today only.' : ` Showing last ${recencyDays} days.`}
  </p>
</AdminLayout>

<OpportunityStatusScript />

<script>
  // Remove button handler (separate from status buttons to handle optimistic removal)
  function initRemoveButtons() {
    document.querySelectorAll<HTMLButtonElement>('.opp-remove-btn').forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';

      btn.addEventListener('click', async () => {
        const oppId = btn.dataset.oppId;
        if (!oppId) return;
        if (btn.disabled) return;

        const row = btn.closest('tr');
        if (!row) return;

        // Optimistic removal: hide row immediately
        btn.disabled = true;
        row.style.transition = 'opacity 0.3s, max-height 0.3s';
        row.style.opacity = '0';

        try {
          const controller = new AbortController();
          const timeout = setTimeout(() => controller.abort(), 15000);

          const res = await fetch(`/admin/api/opportunities/${oppId}/status`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'removed' }),
            signal: controller.signal,
          });

          clearTimeout(timeout);

          if (!res.ok) {
            throw new Error(`HTTP ${res.status}`);
          }

          // Confirmed: remove the row from DOM
          setTimeout(() => row.remove(), 300);
        } catch (err) {
          // Restore row on failure
          row.style.opacity = '1';
          btn.disabled = false;
          console.error('Remove failed:', err);

          // Show inline error
          const cell = btn.closest('td');
          if (cell) {
            const toast = document.createElement('div');
            toast.className = 'absolute mt-1 px-2 py-1 text-xs rounded bg-red-500/20 text-red-400 border border-red-500/30 whitespace-nowrap z-10';
            toast.textContent = 'Failed to remove';
            cell.style.position = 'relative';
            cell.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
          }
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRemoveButtons);
  } else {
    initRemoveButtons();
  }
</script>
