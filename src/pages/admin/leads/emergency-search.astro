---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import { getEmergencyOpportunities, getEmergencyOpportunitySummary } from '../../../lib/admin/opportunities';

export const prerender = false;

const statusFilter = Astro.url.searchParams.get('status') || 'all';
const opportunities = await getEmergencyOpportunities(statusFilter);
const summary = await getEmergencyOpportunitySummary();

function formatRate(min: number | null, max: number | null): string {
  if (!min && !max) return 'Not stated';
  if (min && max && min !== max) return `£${min}-£${max}/day`;
  return `£${min || max}/day`;
}

function formatDate(dateStr: string | null): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}

function scoreColour(score: number | null): string {
  if (!score) return 'text-grey-500';
  if (score >= 60) return 'text-green-400';
  if (score >= 30) return 'text-amber-400';
  return 'text-grey-500';
}

function scoreBg(score: number | null): string {
  if (!score) return 'bg-grey-700/30';
  if (score >= 60) return 'bg-green-500/20';
  if (score >= 30) return 'bg-amber-500/20';
  return 'bg-grey-700/30';
}

const filters = [
  { value: 'all', label: 'All', count: summary.total },
  { value: 'new', label: 'New', count: summary.new },
  { value: 'seen', label: 'Seen', count: summary.seen },
  { value: 'applied', label: 'Applied', count: summary.applied },
];
---

<AdminLayout title="Emergency Job Search">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Leads', href: '/admin/leads/' },
    { label: 'Opportunities', href: '/admin/leads/opportunities' },
    { label: 'Emergency Search' },
  ]} />

  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white font-heading">Emergency Job Search</h1>
        <p class="mt-1 text-sm text-warm-300">Perm and inside IR35 roles matched to your Mosaic CV profile</p>
      </div>
      <a href="/admin/leads/opportunities" class="text-sm text-secondary hover:text-white transition-colors">
        &larr; Outside IR35 roles
      </a>
    </div>
  </div>

  <!-- Info banner -->
  <div class="mb-6 p-3 rounded-lg bg-amber-500/10 border border-amber-500/30">
    <p class="text-sm text-amber-300">
      This page shows roles outside your usual outside IR35 preference, for situations where you need to cast a wider net.
    </p>
  </div>

  <!-- KPI row -->
  <div class="grid gap-4 grid-cols-2 lg:grid-cols-4 mb-8">
    <StatCard label="Total Active" value={String(summary.total)} subtitle="Excluding aged-off" />
    <StatCard label="New" value={String(summary.new)} subtitle="Not yet reviewed" />
    <StatCard label="High Match" value={String(summary.highMatch)} subtitle="60%+ compatibility" trend={summary.highMatch > 0 ? 'up' : undefined} />
    <StatCard label="Applied" value={String(summary.applied)} subtitle="In your pipeline" />
  </div>

  <!-- Filters -->
  <div class="flex gap-2 mb-6">
    {filters.map((f) => (
      <a
        href={`/admin/leads/emergency-search${f.value === 'all' ? '' : `?status=${f.value}`}`}
        class:list={[
          'px-3 py-1.5 text-sm rounded-lg border transition-colors',
          statusFilter === f.value
            ? 'bg-secondary/20 border-secondary text-secondary'
            : 'bg-grey-800 border-grey-700 text-warm-300 hover:border-grey-600',
        ]}
      >
        {f.label} <span class="text-xs opacity-60">({f.count})</span>
      </a>
    ))}
  </div>

  <!-- Opportunities table -->
  <div class="bg-grey-800 rounded-xl border border-grey-700 p-6">
    {opportunities.length === 0 ? (
      <p class="text-sm text-grey-500 text-center py-8">No opportunities found for this filter.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="border-b border-grey-700">
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Match</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Role</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Rate</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Agency</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Location</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden sm:table-cell">IR35</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Posted</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody>
            {opportunities.map((opp) => (
              <tr class:list={[
                'border-b border-grey-700/50 last:border-0',
                opp.status === 'applied' && 'opacity-50',
              ]}>
                <td class="py-3">
                  <span class:list={['inline-flex items-center justify-center w-10 h-6 rounded text-xs font-bold', scoreBg(opp.match_score), scoreColour(opp.match_score)]}>
                    {opp.match_score ?? '-'}%
                  </span>
                </td>
                <td class="py-3">
                  <a href={opp.url} target="_blank" rel="noopener" class="text-white font-medium hover:text-secondary transition-colors">
                    {opp.title.length > 50 ? opp.title.slice(0, 50) + '...' : opp.title}
                  </a>
                  {opp.status === 'new' && (
                    <span class="ml-2 inline-block w-2 h-2 rounded-full bg-blue-400" title="New"></span>
                  )}
                </td>
                <td class="py-3 text-warm-300 hidden md:table-cell">{formatRate(opp.day_rate_min, opp.day_rate_max)}</td>
                <td class="py-3 text-warm-300 hidden lg:table-cell">{opp.agency || '-'}</td>
                <td class="py-3 text-warm-300 hidden lg:table-cell">{opp.location || '-'}</td>
                <td class="py-3 hidden sm:table-cell">
                  <span class:list={[
                    'inline-block px-2 py-0.5 rounded-full text-xs font-medium',
                    opp.ir35_status === 'inside' ? 'bg-amber-500/20 text-amber-400' : 'bg-grey-700/30 text-grey-500',
                  ]}>
                    {opp.ir35_status}
                  </span>
                </td>
                <td class="py-3 text-grey-500 hidden md:table-cell">{formatDate(opp.date_posted)}</td>
                <td class="py-3 flex items-center gap-2">
                  <a
                    href={opp.url}
                    target="_blank"
                    rel="noopener"
                    class="px-3 py-1 text-xs font-medium text-warm-300 bg-grey-700 rounded border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
                  >
                    View
                  </a>
                  {opp.status === 'applied' ? (
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-secondary/20 text-secondary">Applied</span>
                  ) : (
                    <>
                      {opp.status === 'new' && (
                        <button
                          data-opp-id={opp.id}
                          data-action="seen"
                          class="opp-status-btn px-3 py-1 text-xs font-medium text-warm-300 bg-grey-700 rounded border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
                        >
                          Mark Seen
                        </button>
                      )}
                      <button
                        data-opp-id={opp.id}
                        data-action="applied"
                        class="opp-status-btn px-3 py-1 text-xs font-medium text-grey-900 bg-secondary rounded border border-secondary hover:bg-secondary/80 transition-colors"
                      >
                        Applied
                      </button>
                    </>
                  )}
                  {opp.businessmap_card_id && (
                    <a
                      href={`https://smagile.kanbanize.com/ctrl_board/5/cards/${opp.businessmap_card_id}/details`}
                      target="_blank"
                      rel="noopener"
                      class="px-2 py-0.5 text-xs font-medium rounded bg-blue-500/20 text-blue-400 hover:text-blue-300 transition-colors"
                      title="View on Businessmap"
                    >
                      #{opp.businessmap_card_id}
                    </a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Match reasons tooltip area -->
  {opportunities.filter(o => (o.match_score || 0) >= 60).length > 0 && (
    <div class="mt-6 bg-grey-800 rounded-xl border border-grey-700 p-6">
      <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Top Matches</h2>
      <div class="space-y-3">
        {opportunities.filter(o => (o.match_score || 0) >= 60).map((opp) => (
          <div class="p-3 bg-grey-900/50 rounded-lg border border-grey-700/50">
            <div class="flex items-center justify-between mb-1">
              <a href={opp.url} target="_blank" rel="noopener" class="text-sm font-medium text-white hover:text-secondary">
                {opp.title}
              </a>
              <span class="text-sm font-bold text-green-400">{opp.match_score}%</span>
            </div>
            <p class="text-xs text-grey-500">
              {formatRate(opp.day_rate_min, opp.day_rate_max)} · {opp.agency || 'Agency not stated'} · {opp.location || 'Location not stated'}
            </p>
            {opp.match_reasons && (
              <p class="text-xs text-warm-300 mt-1">{opp.match_reasons.join(' · ')}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  <p class="text-xs text-grey-500 text-center mt-6">
    Data sourced from Reed.co.uk. Refreshed twice daily. Opportunities age off after 8 days.
  </p>
</AdminLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.opp-status-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const oppId = btn.dataset.oppId;
      const action = btn.dataset.action;
      if (!oppId || !action) return;

      btn.disabled = true;
      btn.textContent = 'Updating...';

      try {
        const res = await fetch(`/admin/api/opportunities/${oppId}/status`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: action }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Request failed' }));
          throw new Error(err.error || `HTTP ${res.status}`);
        }

        const data = await res.json();

        // Find the parent row and update it
        const row = btn.closest('tr');
        if (!row) return;

        if (action === 'applied') {
          row.classList.add('opacity-50');
          // Replace all buttons in the actions cell with an Applied badge
          const cell = btn.closest('td');
          if (cell) {
            // Remove all status buttons
            cell.querySelectorAll('.opp-status-btn').forEach((b) => b.remove());
            // Insert Applied badge
            const badge = document.createElement('span');
            badge.className = 'px-2 py-0.5 text-xs font-medium rounded-full bg-secondary/20 text-secondary';
            badge.textContent = 'Applied';
            cell.appendChild(badge);

            // Add Businessmap card link if we got a card_id
            if (data.businessmap_card_id) {
              const link = document.createElement('a');
              link.href = `https://smagile.kanbanize.com/ctrl_board/5/cards/${data.businessmap_card_id}/details`;
              link.target = '_blank';
              link.rel = 'noopener';
              link.className = 'px-2 py-0.5 text-xs font-medium rounded bg-blue-500/20 text-blue-400 hover:text-blue-300 transition-colors';
              link.title = 'View on Businessmap';
              link.textContent = `#${data.businessmap_card_id}`;
              cell.appendChild(link);
            }
          }
        } else if (action === 'seen') {
          // Remove the "new" blue dot indicator
          const dot = row.querySelector('.bg-blue-400');
          if (dot) dot.remove();
          // Remove the Mark Seen button
          btn.remove();
        }
      } catch (err) {
        console.error('Status update failed:', err);
        btn.disabled = false;
        btn.textContent = action === 'applied' ? 'Applied' : 'Mark Seen';
        alert(`Failed to update status: ${err instanceof Error ? err.message : 'Unknown error'}`);
      }
    });
  });
</script>
