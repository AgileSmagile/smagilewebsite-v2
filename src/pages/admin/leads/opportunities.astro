---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import OpportunityStatusScript from '../../../components/admin/OpportunityStatusScript.astro';
import { getOpportunities, getOpportunitySummary, getSourceCounts } from '../../../lib/admin/opportunities';

export const prerender = false;

// Read all filter params from URL
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const sourceFilter = Astro.url.searchParams.get('source') || 'all';
const minScore = parseInt(Astro.url.searchParams.get('min_score') || '0', 10) || 0;
const minRate = parseInt(Astro.url.searchParams.get('min_rate') || '0', 10) || 0;
const sortBy = Astro.url.searchParams.get('sort') || 'score';
const hideSeen = Astro.url.searchParams.get('hide_seen') === '1';

const opportunities = await getOpportunities({
  status: statusFilter,
  source: sourceFilter,
  minScore,
  minRate,
  sort: sortBy,
  hideSeen,
});
const summary = await getOpportunitySummary();
const sourceCounts = await getSourceCounts();

function formatRate(min: number | null, max: number | null): string {
  if (!min && !max) return 'Not stated';
  if (min && max && min !== max) return `£${min}-£${max}/day`;
  return `£${min || max}/day`;
}

function formatDate(dateStr: string | null): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}

function scoreColour(score: number | null): string {
  if (!score) return 'text-grey-500';
  if (score >= 60) return 'text-green-400';
  if (score >= 30) return 'text-amber-400';
  return 'text-grey-500';
}

function scoreBg(score: number | null): string {
  if (!score) return 'bg-grey-700/30';
  if (score >= 60) return 'bg-green-500/20';
  if (score >= 30) return 'bg-amber-500/20';
  return 'bg-grey-700/30';
}

/** Build a URL preserving current filters but overriding one param */
function filterUrl(overrides: Record<string, string>): string {
  const params = new URLSearchParams();
  const current: Record<string, string> = {
    status: statusFilter,
    source: sourceFilter,
    min_score: String(minScore),
    min_rate: String(minRate),
    sort: sortBy,
    hide_seen: hideSeen ? '1' : '0',
  };
  const merged = { ...current, ...overrides };
  for (const [k, v] of Object.entries(merged)) {
    // Skip defaults to keep URL clean
    if (k === 'status' && v === 'all') continue;
    if (k === 'source' && v === 'all') continue;
    if (k === 'min_score' && v === '0') continue;
    if (k === 'min_rate' && v === '0') continue;
    if (k === 'sort' && v === 'score') continue;
    if (k === 'hide_seen' && v === '0') continue;
    params.set(k, v);
  }
  const qs = params.toString();
  return `/admin/leads/opportunities${qs ? '?' + qs : ''}`;
}

const statusOptions = [
  { value: 'all', label: 'All', count: summary.total },
  { value: 'new', label: 'New', count: summary.new },
  { value: 'seen', label: 'Seen', count: summary.seen },
  { value: 'applied', label: 'Applied', count: summary.applied },
];

const sourceOptions = [
  { value: 'all', label: 'All sources', count: summary.total },
  ...Object.entries(sourceCounts).map(([k, v]) => ({
    value: k,
    label: k.charAt(0).toUpperCase() + k.slice(1),
    count: v,
  })),
];

const scoreOptions = [
  { value: '0', label: 'Any score' },
  { value: '30', label: '30%+' },
  { value: '60', label: '60%+ (high)' },
];

const sortOptions = [
  { value: 'score', label: 'Match score' },
  { value: 'date', label: 'Date posted' },
  { value: 'rate', label: 'Day rate' },
];
---

<AdminLayout title="Job Opportunities">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Leads', href: '/admin/leads/' },
    { label: 'Opportunities' },
  ]} />

  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white font-heading">Job Opportunities</h1>
        <p class="mt-1 text-sm text-warm-300">Outside IR35 contract roles matched to your profile</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/admin/leads/partner-opportunities" class="px-3 py-1.5 text-sm font-medium text-warm-300 bg-grey-700 rounded-lg border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors">
          Partner Network
        </a>
        <a href="/admin/leads/emergency-search" class="px-3 py-1.5 text-sm font-medium text-amber-300 bg-amber-500/10 rounded-lg border border-amber-500/30 hover:bg-amber-500/20 transition-colors">
          Emergency Search
        </a>
        <a href="/admin/leads/" class="text-sm text-secondary hover:text-white transition-colors">
          &larr; Back to Leads
        </a>
      </div>
    </div>
  </div>

  <!-- KPI row -->
  <div class="grid gap-4 grid-cols-2 lg:grid-cols-4 mb-8">
    <StatCard label="Total Active" value={String(summary.total)} subtitle="Excluding aged-off" />
    <StatCard label="New" value={String(summary.new)} subtitle="Not yet reviewed" />
    <StatCard label="High Match" value={String(summary.highMatch)} subtitle="60%+ compatibility" trend={summary.highMatch > 0 ? 'up' : undefined} />
    <StatCard label="Applied" value={String(summary.applied)} subtitle="In your pipeline" />
  </div>

  <!-- Filter bar -->
  <div class="bg-grey-800 rounded-xl border border-grey-700 p-4 mb-6">
    <div class="flex flex-wrap items-center gap-3">
      <!-- Status -->
      <div class="flex gap-1">
        {statusOptions.map((f) => (
          <a
            href={filterUrl({ status: f.value })}
            class:list={[
              'px-2.5 py-1 text-xs rounded-lg border transition-colors',
              statusFilter === f.value
                ? 'bg-secondary/20 border-secondary text-secondary'
                : 'bg-grey-900 border-grey-700 text-warm-300 hover:border-grey-600',
            ]}
          >
            {f.label} <span class="opacity-50">({f.count})</span>
          </a>
        ))}
      </div>

      <span class="text-grey-600">|</span>

      <!-- Source -->
      <div class="flex gap-1">
        {sourceOptions.map((s) => (
          <a
            href={filterUrl({ source: s.value })}
            class:list={[
              'px-2.5 py-1 text-xs rounded-lg border transition-colors',
              sourceFilter === s.value
                ? 'bg-secondary/20 border-secondary text-secondary'
                : 'bg-grey-900 border-grey-700 text-warm-300 hover:border-grey-600',
            ]}
          >
            {s.label} <span class="opacity-50">({s.count})</span>
          </a>
        ))}
      </div>

      <span class="text-grey-600">|</span>

      <!-- Min score -->
      <div class="flex gap-1">
        {scoreOptions.map((s) => (
          <a
            href={filterUrl({ min_score: s.value })}
            class:list={[
              'px-2.5 py-1 text-xs rounded-lg border transition-colors',
              String(minScore) === s.value
                ? 'bg-secondary/20 border-secondary text-secondary'
                : 'bg-grey-900 border-grey-700 text-warm-300 hover:border-grey-600',
            ]}
          >
            {s.label}
          </a>
        ))}
      </div>

      <span class="text-grey-600">|</span>

      <!-- Sort -->
      <div class="flex gap-1">
        {sortOptions.map((s) => (
          <a
            href={filterUrl({ sort: s.value })}
            class:list={[
              'px-2.5 py-1 text-xs rounded-lg border transition-colors',
              sortBy === s.value
                ? 'bg-secondary/20 border-secondary text-secondary'
                : 'bg-grey-900 border-grey-700 text-warm-300 hover:border-grey-600',
            ]}
          >
            {s.label}
          </a>
        ))}
      </div>

      <span class="text-grey-600">|</span>

      <!-- Hide seen toggle -->
      <a
        href={filterUrl({ hide_seen: hideSeen ? '0' : '1' })}
        class:list={[
          'px-2.5 py-1 text-xs rounded-lg border transition-colors',
          hideSeen
            ? 'bg-secondary/20 border-secondary text-secondary'
            : 'bg-grey-900 border-grey-700 text-warm-300 hover:border-grey-600',
        ]}
      >
        Hide seen
      </a>

      <!-- Result count + clear -->
      <span class="ml-auto text-xs text-grey-500">
        {opportunities.length} results
      </span>
      {(statusFilter !== 'all' || sourceFilter !== 'all' || minScore > 0 || minRate > 0 || sortBy !== 'score' || hideSeen) && (
        <a href="/admin/leads/opportunities" class="text-xs text-secondary hover:text-white transition-colors">
          Clear all
        </a>
      )}
    </div>
  </div>

  <!-- Opportunities table -->
  <div class="bg-grey-800 rounded-xl border border-grey-700 p-6">
    {opportunities.length === 0 ? (
      <p class="text-sm text-grey-500 text-center py-8">No opportunities found for these filters.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="border-b border-grey-700">
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Match</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Role</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Rate</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Agency</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden lg:table-cell">Location</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden sm:table-cell">Source</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Posted</th>
              <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody>
            {opportunities.map((opp) => (
              <tr class:list={[
                'border-b border-grey-700/50 last:border-0',
                opp.status === 'applied' && 'opacity-50',
              ]}>
                <td class="py-3">
                  <span class:list={['inline-flex items-center justify-center w-10 h-6 rounded text-xs font-bold', scoreBg(opp.match_score), scoreColour(opp.match_score)]}>
                    {opp.match_score ?? '-'}%
                  </span>
                </td>
                <td class="py-3">
                  <a href={opp.url} target="_blank" rel="noopener" class="text-white font-medium hover:text-secondary transition-colors">
                    {opp.title.length > 50 ? opp.title.slice(0, 50) + '...' : opp.title}
                  </a>
                  {opp.status === 'new' && (
                    <span class="ml-2 inline-block w-2 h-2 rounded-full bg-blue-400" title="New"></span>
                  )}
                </td>
                <td class="py-3 text-warm-300 hidden md:table-cell">{formatRate(opp.day_rate_min, opp.day_rate_max)}</td>
                <td class="py-3 text-warm-300 hidden lg:table-cell">{opp.agency || '-'}</td>
                <td class="py-3 text-warm-300 hidden lg:table-cell">{(opp.location || '-').length > 20 ? opp.location!.slice(0, 20) + '...' : opp.location || '-'}</td>
                <td class="py-3 hidden sm:table-cell">
                  <span class="text-xs text-grey-500">{opp.source}</span>
                </td>
                <td class="py-3 text-grey-500 hidden md:table-cell">{formatDate(opp.date_posted)}</td>
                <td class="py-3 flex items-center gap-2">
                  <a
                    href={opp.url}
                    target="_blank"
                    rel="noopener"
                    class="px-3 py-1 text-xs font-medium text-warm-300 bg-grey-700 rounded border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
                  >
                    View
                  </a>
                  {opp.status === 'applied' ? (
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-secondary/20 text-secondary">Applied</span>
                  ) : (
                    <>
                      {opp.status === 'new' && (
                        <button
                          data-opp-id={opp.id}
                          data-action="seen"
                          class="opp-status-btn px-3 py-1 text-xs font-medium text-warm-300 bg-grey-700 rounded border border-grey-600 hover:bg-grey-600 hover:text-white transition-colors"
                        >
                          Mark Seen
                        </button>
                      )}
                      <button
                        data-opp-id={opp.id}
                        data-action="applied"
                        class="opp-status-btn px-3 py-1 text-xs font-medium text-grey-900 bg-secondary rounded border border-secondary hover:bg-secondary/80 transition-colors"
                      >
                        Applied
                      </button>
                    </>
                  )}
                  {opp.businessmap_card_id && (
                    <a
                      href={`https://smagile.kanbanize.com/ctrl_board/5/cards/${opp.businessmap_card_id}/details`}
                      target="_blank"
                      rel="noopener"
                      class="px-2 py-0.5 text-xs font-medium rounded bg-blue-500/20 text-blue-400 hover:text-blue-300 transition-colors"
                      title="View on Businessmap"
                    >
                      #{opp.businessmap_card_id}
                    </a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <p class="text-xs text-grey-500 text-center mt-6">
    Data sourced from Reed.co.uk and Adzuna. Refreshed twice daily. Opportunities age off after 8 days.
  </p>
</AdminLayout>

<OpportunityStatusScript />
