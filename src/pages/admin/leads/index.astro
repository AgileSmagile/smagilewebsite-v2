---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';

export const prerender = false;

const stages = [
  { label: 'New', count: 8, colour: 'bg-blue-500' },
  { label: 'Contacted', count: 7, colour: 'bg-amber-500' },
  { label: 'Qualified', count: 4, colour: 'bg-purple-500' },
  { label: 'Proposal Sent', count: 2, colour: 'bg-secondary' },
  { label: 'Won', count: 2, colour: 'bg-green-500' },
];

const totalLeads = stages.reduce((sum, s) => sum + s.count, 0);

const leads = [
  { name: 'Sarah Mitchell', company: 'Barclays', source: 'LinkedIn', status: 'Qualified', lastContact: '12 Mar 2026' },
  { name: 'David Chen', company: 'Nationwide Building Society', source: 'Referral', status: 'Contacted', lastContact: '11 Mar 2026' },
  { name: 'Priya Sharma', company: 'Rolls-Royce', source: 'LinkedIn', status: 'New', lastContact: '10 Mar 2026' },
  { name: 'Tom Williams', company: 'Deloitte', source: 'Job Board', status: 'Proposal Sent', lastContact: '9 Mar 2026' },
  { name: 'Rachel Adams', company: 'DVLA', source: 'LinkedIn', status: 'Won', lastContact: '7 Mar 2026' },
  { name: 'James Okonkwo', company: 'Sky', source: 'Referral', status: 'New', lastContact: '6 Mar 2026' },
  { name: 'Emma Clarke', company: 'Vodafone', source: 'LinkedIn', status: 'Contacted', lastContact: '5 Mar 2026' },
  { name: 'Michael Byrne', company: 'AstraZeneca', source: 'Job Board', status: 'Qualified', lastContact: '4 Mar 2026' },
];

const statusColours: Record<string, string> = {
  'New': 'bg-blue-500/20 text-blue-400',
  'Contacted': 'bg-amber-500/20 text-amber-400',
  'Qualified': 'bg-purple-500/20 text-purple-400',
  'Proposal Sent': 'bg-secondary/20 text-secondary',
  'Won': 'bg-green-500/20 text-green-400',
};

const sourceIcons: Record<string, string> = {
  'LinkedIn': 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z',
  'Referral': 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  'Job Board': 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
};

const templates = [
  { name: 'Initial LinkedIn connection request', description: 'Personalised connection message for new prospects' },
  { name: 'Follow-up after no response (7 days)', description: 'Gentle nudge with added value or insight' },
  { name: 'Discovery call invitation', description: 'Propose a short call to explore fit' },
];
---

<AdminLayout title="Lead Gen & Outreach">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Leads' },
  ]} />

  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white font-heading">Lead Gen & Outreach</h1>
        <p class="mt-1 text-sm text-warm-300">Track prospects, manage outreach, and monitor your pipeline</p>
      </div>
      <div class="flex items-center gap-3">
        <a href="/admin/leads/outreach" class="px-4 py-2 text-sm font-medium text-warm-300 bg-grey-800 rounded-lg border border-grey-700 hover:border-grey-600 hover:text-white transition-colors inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38a.75.75 0 01-1.006-.267 11.247 11.247 0 01-1.59-4.227m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46" />
          </svg>
          Outreach
        </a>
        <a href="/admin/leads/emergency-search" class="px-4 py-2 text-sm font-medium text-amber-300 bg-amber-500/10 rounded-lg border border-amber-500/30 hover:bg-amber-500/20 transition-colors">
          Emergency Search
        </a>
        <a href="/admin/leads/opportunities" class="px-4 py-2 text-sm font-medium text-white bg-secondary rounded-lg hover:bg-secondary/80 transition-colors">
          Job Opportunities &rarr;
        </a>
      </div>
    </div>
  </div>

  <!-- KPI row -->
  <div class="grid gap-4 grid-cols-2 lg:grid-cols-4 mb-8">
    <StatCard label="Pipeline Total" value="23" subtitle="Across all stages" />
    <StatCard label="Contacted This Week" value="7" subtitle="Up from 5 last week" trend="up" />
    <StatCard label="Response Rate" value="31%" subtitle="Industry avg ~20%" trend="up" />
    <StatCard label="Qualified Leads" value="4" subtitle="Ready for proposals" />
  </div>

  <!-- Pipeline summary -->
  <div class="mb-8 bg-grey-800 rounded-xl border border-grey-700 p-6">
    <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Pipeline Stages</h2>

    <!-- Stage bar -->
    <div class="flex rounded-lg overflow-hidden h-8 mb-4">
      {stages.map((stage) => (
        <div
          class:list={[stage.colour, 'flex items-center justify-center text-xs font-medium text-white min-w-[2rem]']}
          style={`width: ${(stage.count / totalLeads) * 100}%`}
          title={`${stage.label}: ${stage.count}`}
        >
          {stage.count}
        </div>
      ))}
    </div>

    <!-- Stage labels -->
    <div class="flex flex-wrap gap-4">
      {stages.map((stage) => (
        <div class="flex items-center gap-2">
          <span class:list={['w-3 h-3 rounded-sm', stage.colour]}></span>
          <span class="text-sm text-warm-300">{stage.label}</span>
          <span class="text-sm font-semibold text-white">{stage.count}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Recent leads table -->
  <div class="mb-8 bg-grey-800 rounded-xl border border-grey-700 p-6">
    <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Recent Leads</h2>

    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="border-b border-grey-700">
            <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Name</th>
            <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Company</th>
            <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden sm:table-cell">Source</th>
            <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Status</th>
            <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider hidden md:table-cell">Last Contact</th>
            <th class="pb-3 text-xs font-medium text-warm-300 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody>
          {leads.map((lead) => (
            <tr class="border-b border-grey-700/50 last:border-0">
              <td class="py-3 text-white font-medium">{lead.name}</td>
              <td class="py-3 text-warm-300">{lead.company}</td>
              <td class="py-3 hidden sm:table-cell">
                <span class="inline-flex items-center gap-1.5 text-warm-300">
                  <svg class="w-3.5 h-3.5 text-grey-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={sourceIcons[lead.source]} />
                  </svg>
                  {lead.source}
                </span>
              </td>
              <td class="py-3">
                <span class:list={['inline-block px-2 py-0.5 rounded-full text-xs font-medium', statusColours[lead.status]]}>
                  {lead.status}
                </span>
              </td>
              <td class="py-3 text-grey-500 hidden md:table-cell">{lead.lastContact}</td>
              <td class="py-3">
                <button
                  disabled
                  class="px-3 py-1 text-xs font-medium text-grey-500 bg-grey-700 rounded border border-grey-600 cursor-not-allowed"
                >
                  View
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Outreach templates -->
  <div class="mb-8 bg-grey-800 rounded-xl border border-grey-700 p-6">
    <h2 class="text-sm font-medium text-warm-300 uppercase tracking-wider mb-4">Outreach Templates</h2>

    <div class="space-y-3">
      {templates.map((tpl) => (
        <div class="flex items-center justify-between p-3 bg-grey-900/50 rounded-lg border border-grey-700/50">
          <div>
            <p class="text-sm font-medium text-white">{tpl.name}</p>
            <p class="text-xs text-grey-500 mt-0.5">{tpl.description}</p>
          </div>
          <button
            disabled
            class="px-3 py-1 text-xs font-medium text-grey-500 bg-grey-700 rounded border border-grey-600 cursor-not-allowed shrink-0 ml-4"
          >
            Edit
          </button>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom note -->
  <p class="text-xs text-grey-500 text-center">
    Live data integration coming soon. This view shows placeholder data.
  </p>
</AdminLayout>
