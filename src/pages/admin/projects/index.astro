---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Breadcrumb from '../../../components/admin/Breadcrumb.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import AgentCard from '../../../components/admin/AgentCard.astro';
import AuditPanel from '../../../components/admin/AuditPanel.astro';
import { getAgentStatuses } from '../../../lib/admin/agents';
import { projects, type ProjectInfo } from '../../../lib/admin/projects';
import { getSupabaseAdmin } from '../../../lib/admin/supabase';
import {
  getMosaicMetrics,
  getTrend,
  formatNumber,
  formatDuration,
  formatPct,
  formatRelativeDate,
  formatFilePath,
  estimateAiCost,
  type ProjectMetrics,
  type Trend,
} from '../../../lib/admin/metrics';

export const prerender = false;

// Check Supabase connectivity
const supabaseConfigured = !!getSupabaseAdmin();

// Fetch all data in parallel
const [agents, mosaicMetrics] = await Promise.all([
  getAgentStatuses(),
  supabaseConfigured ? getMosaicMetrics() : null,
]);

const onlineCount = agents.filter((a) => a.status === 'online').length;
const totalAgentCount = agents.length;

// Determine active project tab from query string
const activeTab = Astro.url.searchParams.get('project') ?? 'mosaic-cv';

// Code health helpers
const ch = mosaicMetrics?.codeHealth;
const latest = ch?.latest;
const prev = ch?.previous;

// Usage helpers
const usage = mosaicMetrics?.usage;

// AI usage helpers
const aiUsage = mosaicMetrics?.aiUsage;

// Funnel helpers
const funnel = mosaicMetrics?.funnel;

// Error rate calculation
const errorRate = usage && usage.totalOutputAttempts > 0
  ? ((usage.failedOutputs / usage.totalOutputAttempts) * 100)
  : null;

/**
 * For metrics where lower is better (errors, vulnerabilities), invert the trend
 * so that "down" shows green and "up" shows red.
 */
function invertTrend(t: Trend): Trend {
  if (t === 'up') return 'down';
  if (t === 'down') return 'up';
  return 'flat';
}

/** Funnel bar width as a percentage of the max (total signups). */
function funnelPct(value: number, max: number): number {
  if (max <= 0) return 0;
  return Math.max(4, Math.round((value / max) * 100));
}
---

<AdminLayout title="Projects & Agents">
  <Breadcrumb segments={[
    { label: 'Dashboard', href: '/admin/' },
    { label: 'Projects & Agents' },
  ]} />

  {/* ── Project tabs ── */}
  <nav class="flex gap-1 mb-6 border-b border-grey-700" aria-label="Project tabs">
    {projects.map((project) => (
      <a
        href={`/admin/projects/?project=${project.id}`}
        class:list={[
          'px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2',
          activeTab === project.id
            ? 'text-secondary border-secondary'
            : 'text-warm-300 border-transparent hover:text-white hover:border-grey-500',
        ]}
      >
        {project.name}
      </a>
    ))}
  </nav>

  {/* ── Mosaic CV ── */}
  {activeTab === 'mosaic-cv' && (
    <div>
      <div class="mb-4">
        <h2 class="text-xl font-bold text-white font-heading">Mosaic CV</h2>
        <p class="mt-0.5 text-sm text-warm-300">mosaic.smagile.co</p>
      </div>

      {/* Missing env vars warning */}
      {!supabaseConfigured && (
        <div class="p-4 mb-4 bg-amber-900/30 rounded-xl border border-amber-700/50">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-amber-200">Supabase not configured</p>
              <p class="mt-1 text-xs text-amber-300/80">
                Add <code class="font-mono bg-amber-900/50 px-1 rounded">SUPABASE_URL</code> and
                <code class="font-mono bg-amber-900/50 px-1 rounded">SUPABASE_SERVICE_ROLE_KEY</code> to your
                <code class="font-mono bg-amber-900/50 px-1 rounded">.env</code> file to enable live metrics.
              </p>
            </div>
          </div>
        </div>
      )}

      {/* Connection error */}
      {supabaseConfigured && mosaicMetrics && mosaicMetrics.errors.length > 0 && (
        <div class="p-4 mb-4 bg-red-900/30 rounded-xl border border-red-700/50">
          <p class="text-sm font-medium text-red-200 mb-2">Some metrics failed to load</p>
          <ul class="text-xs text-red-300/80 space-y-1">
            {mosaicMetrics.errors.map((e) => (
              <li>{e.section}: {e.message}</li>
            ))}
          </ul>
        </div>
      )}

      {/* ── Code Health ── */}
      <section class="mb-6">
        <h3 class="text-lg font-semibold text-white mb-3">Code Health</h3>
        {latest ? (
          <>
            <div class="grid gap-3 grid-cols-2 lg:grid-cols-4 mb-3">
              <StatCard
                label="Lines of Code"
                value={formatNumber(latest.sloc ?? latest.lines_of_code)}
                subtitle={latest.sloc ? 'Source lines (excl. blanks/comments)' : 'Total lines'}
                trend={getTrend(latest.sloc ?? latest.lines_of_code, prev?.sloc ?? prev?.lines_of_code)}
              />
              <StatCard
                label="Tests"
                value={formatNumber(latest.test_count)}
                subtitle={latest.tests_passing !== null
                  ? `${latest.tests_passing} passing, ${latest.tests_failing ?? 0} failing`
                  : undefined}
                trend={getTrend(latest.test_count, prev?.test_count)}
              />
              <StatCard
                label="Coverage"
                value={formatPct(latest.test_coverage_pct)}
                subtitle="Test coverage"
                trend={getTrend(latest.test_coverage_pct, prev?.test_coverage_pct)}
              />
              <StatCard
                label="Vulnerabilities"
                value={formatNumber((latest.vuln_critical ?? 0) + (latest.vuln_high ?? 0) + (latest.vuln_moderate ?? 0))}
                subtitle={latest.vuln_critical
                  ? `${latest.vuln_critical} critical, ${latest.vuln_high ?? 0} high`
                  : 'npm audit'}
                trend={invertTrend(getTrend(
                  (latest.vuln_critical ?? 0) + (latest.vuln_high ?? 0),
                  (prev?.vuln_critical ?? 0) + (prev?.vuln_high ?? 0),
                ))}
              />
              <StatCard
                label="Build Time"
                value={formatDuration(latest.build_time_ms)}
                subtitle="Production build"
                trend={invertTrend(getTrend(latest.build_time_ms, prev?.build_time_ms))}
              />
              <StatCard
                label="Bundle Size"
                value={latest.bundle_size_kb !== null ? `${latest.bundle_size_kb}KB` : '--'}
                subtitle="Client bundle"
                trend={invertTrend(getTrend(latest.bundle_size_kb, prev?.bundle_size_kb))}
              />
              <StatCard
                label="Lint Errors"
                value={formatNumber(latest.lint_errors)}
                subtitle={latest.lint_warnings !== null ? `${latest.lint_warnings} warnings` : undefined}
                trend={invertTrend(getTrend(latest.lint_errors, prev?.lint_errors))}
              />
              <StatCard
                label="TODOs / FIXMEs"
                value={formatNumber(latest.todo_fixme_count)}
                subtitle="In codebase"
                trend={invertTrend(getTrend(latest.todo_fixme_count, prev?.todo_fixme_count))}
              />
            </div>

            {/* Secondary code health row */}
            <div class="grid gap-3 grid-cols-2 lg:grid-cols-4 mb-3">
              <StatCard
                label="Change Velocity"
                value={latest.insertions_30d !== null
                  ? `+${formatNumber(latest.insertions_30d)} / -${formatNumber(latest.deletions_30d)}`
                  : '--'}
                subtitle="Last 30 days"
              />
              <StatCard
                label="Last Snapshot"
                value={formatRelativeDate(latest.created_at)}
                subtitle={new Date(latest.created_at).toLocaleDateString('en-GB', {
                  day: 'numeric', month: 'short', year: 'numeric',
                })}
              />
            </div>

            {/* ── Detailed Audit Data ── */}
            {(latest.top_files || latest.lines_by_directory || latest.bloat_files || latest.todo_hotspots || latest.git_churn || latest.type_definitions || latest.file_type_breakdown) && (
              <div class="grid gap-3 grid-cols-1 lg:grid-cols-2 mt-3">
                <AuditPanel
                  title="Largest Files"
                  countLabel="files"
                  items={(latest.top_files ?? []).map((f) => ({ label: formatFilePath(f.path), value: `${formatNumber(f.lines)} lines` }))}
                />
                <AuditPanel
                  title="Lines by Directory"
                  countLabel="dirs"
                  items={(latest.lines_by_directory ?? []).map((d) => ({ label: d.directory, value: `${formatNumber(d.lines)} LOC` }))}
                />
                <AuditPanel
                  title="Bloat Signals"
                  countLabel="files over 300 lines"
                  items={(latest.bloat_files ?? []).map((f) => ({ label: formatFilePath(f.path), value: `${formatNumber(f.lines)} lines` }))}
                />
                <AuditPanel
                  title="TODO Hotspots"
                  countLabel="files"
                  items={(latest.todo_hotspots ?? []).map((f) => ({ label: formatFilePath(f.path), value: `${f.count} TODOs` }))}
                />
                <AuditPanel
                  title="Git Churn (7 days)"
                  countLabel="files"
                  items={(latest.git_churn ?? []).map((f) => ({ label: formatFilePath(f.path), value: `${f.changes} changes` }))}
                />
                <AuditPanel
                  title="Type Definitions"
                  countLabel="files"
                  items={(latest.type_definitions ?? []).map((f) => ({ label: formatFilePath(f.path), value: `${f.count} types` }))}
                />
                <AuditPanel
                  title="File Types"
                  countLabel="types"
                  items={(latest.file_type_breakdown ?? []).map((f) => ({ label: f.extension, value: `${formatNumber(f.lines)} lines / ${f.files} files` }))}
                />
              </div>
            )}
          </>
        ) : supabaseConfigured ? (
          <div class="p-4 bg-grey-800 rounded-xl border border-grey-700">
            <p class="text-sm text-warm-300">No code health snapshots found. Data is collected on each push to main.</p>
          </div>
        ) : null}
      </section>

      {/* ── Usage Overview ── */}
      {supabaseConfigured && (
        <section class="mb-6">
          <h3 class="text-lg font-semibold text-white mb-3">Usage Overview</h3>
          {usage ? (
            <>
              <div class="grid gap-3 grid-cols-2 lg:grid-cols-4 mb-3">
                <StatCard label="Total Users" value={formatNumber(usage.totalUsers)} />
                <StatCard
                  label="DAU (est.)"
                  value={formatNumber(usage.dauEstimate)}
                  subtitle="Last 24 hours"
                  title="Daily Active Users: unique users who generated a CV in the last 24 hours"
                />
                <StatCard
                  label="WAU (est.)"
                  value={formatNumber(usage.wauEstimate)}
                  subtitle="Last 7 days"
                  title="Weekly Active Users: unique users who generated a CV in the last 7 days"
                />
                <StatCard
                  label="MAU (est.)"
                  value={formatNumber(usage.mauEstimate)}
                  subtitle="Last 30 days"
                  title="Monthly Active Users: unique users who generated a CV in the last 30 days"
                />
              </div>
              <div class="grid gap-3 grid-cols-2 lg:grid-cols-4 mb-3">
                <StatCard label="Total Outputs" value={formatNumber(usage.totalOutputs)} subtitle="Completed CVs + variants" />
                <StatCard label="Outputs This Week" value={formatNumber(usage.outputsThisWeek)} />
                <StatCard
                  label="Error Rate"
                  value={errorRate !== null ? formatPct(errorRate) : '--'}
                  subtitle={`${usage.failedOutputs} failed of ${usage.totalOutputAttempts} attempts`}
                  trend={errorRate !== null && errorRate > 5 ? 'down' : 'flat'}
                />

                {/* Subscription breakdown inline */}
                {Object.keys(usage.subscriptionBreakdown).length > 0 && (
                  <div class="p-4 bg-grey-800 rounded-xl border border-grey-700">
                    <p class="text-xs font-medium text-warm-300 uppercase tracking-wider mb-2">Subscription Tiers</p>
                    <div class="flex flex-wrap gap-3">
                      {Object.entries(usage.subscriptionBreakdown).map(([tier, count]) => (
                        <div class="text-center">
                          <p class="text-lg font-bold text-white font-heading">{count}</p>
                          <p class="text-xs text-grey-500">{tier}</p>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </>
          ) : (
            <div class="p-4 bg-grey-800 rounded-xl border border-grey-700">
              <p class="text-sm text-warm-300">Usage data unavailable.</p>
            </div>
          )}
        </section>
      )}

      {/* ── Product Health / Funnel + AI Usage side by side on desktop ── */}
      <div class="grid gap-6 grid-cols-1 lg:grid-cols-2 mb-6">
        {/* Product Health / Funnel */}
        {supabaseConfigured && funnel && (
          <section>
            <h3 class="text-lg font-semibold text-white mb-3">Product Health</h3>
            <div class="p-4 bg-grey-800 rounded-xl border border-grey-700">
              <p class="text-xs font-medium text-warm-300 uppercase tracking-wider mb-3">User Funnel</p>
              <div class="space-y-2.5">
                {[
                  { label: 'Signed up', value: funnel.totalSignups },
                  { label: 'Created a CV', value: funnel.usersWithCv },
                  { label: 'Created 2+ CVs', value: funnel.usersWithMultipleCvs },
                  { label: 'Exported', value: funnel.usersWhoExported },
                ].map((step) => (
                  <div>
                    <div class="flex items-center justify-between text-sm mb-1">
                      <span class="text-warm-300">{step.label}</span>
                      <span class="text-white font-mono font-medium">{step.value}</span>
                    </div>
                    <div class="w-full bg-grey-700 rounded-full h-2">
                      <div
                        class="bg-secondary rounded-full h-2 transition-all"
                        style={`width: ${funnelPct(step.value, funnel.totalSignups)}%`}
                      />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
        )}

        {/* AI Usage */}
        {supabaseConfigured && (
          <section>
            <h3 class="text-lg font-semibold text-white mb-3">AI Usage</h3>
            {aiUsage ? (
              <div class="space-y-3">
                <div class="grid gap-3 grid-cols-2">
                  <StatCard
                    label="Total Tokens"
                    value={formatNumber(aiUsage.totalTokens)}
                    subtitle={`Est. cost: ${estimateAiCost(aiUsage.totalTokens)}`}
                  />
                  <StatCard label="Unique Users" value={formatNumber(aiUsage.uniqueUsers)} subtitle="Used AI features" />
                </div>
                <StatCard label="Avg per User" value={formatNumber(aiUsage.avgTokensPerUser)} subtitle="Tokens" />

                {/* Interaction breakdown */}
                {Object.keys(aiUsage.interactionBreakdown).length > 0 && (
                  <div class="p-4 bg-grey-800 rounded-xl border border-grey-700">
                    <p class="text-xs font-medium text-warm-300 uppercase tracking-wider mb-2">Tokens by Interaction Type</p>
                    <div class="grid grid-cols-1 gap-1.5">
                      {Object.entries(aiUsage.interactionBreakdown)
                        .sort(([, a], [, b]) => b - a)
                        .map(([type, tokens]) => (
                          <div class="flex items-center justify-between p-1.5 bg-grey-900 rounded-lg">
                            <span class="text-xs text-warm-300 truncate mr-2">{type}</span>
                            <span class="text-xs text-white font-mono whitespace-nowrap">{formatNumber(tokens)}</span>
                          </div>
                        ))}
                    </div>
                  </div>
                )}
              </div>
            ) : (
              <div class="p-4 bg-grey-800 rounded-xl border border-grey-700">
                <p class="text-sm text-warm-300">AI usage data unavailable.</p>
              </div>
            )}
          </section>
        )}
      </div>

      {/* ── Placeholder metrics (coming soon) ── */}
      <section class="mb-6">
        <h3 class="text-lg font-semibold text-white mb-3">
          Operational Metrics
          <span class="text-xs font-normal text-grey-500 ml-2">coming soon</span>
        </h3>
        <div class="grid gap-3 grid-cols-2 lg:grid-cols-3">
          <div class="p-4 bg-grey-800/50 rounded-xl border border-grey-700/50 border-dashed">
            <p class="text-xs font-medium text-warm-300/60 uppercase tracking-wider">Time Since Last Deploy</p>
            <p class="mt-2 text-2xl font-bold text-grey-600 font-heading">--</p>
            <p class="mt-1 text-xs text-grey-600">Coming soon</p>
          </div>
          <div class="p-4 bg-grey-800/50 rounded-xl border border-grey-700/50 border-dashed">
            <p class="text-xs font-medium text-warm-300/60 uppercase tracking-wider">Release Frequency</p>
            <p class="mt-2 text-2xl font-bold text-grey-600 font-heading">--</p>
            <p class="mt-1 text-xs text-grey-600">Deploys per week</p>
          </div>
          <div class="p-4 bg-grey-800/50 rounded-xl border border-grey-700/50 border-dashed">
            <p class="text-xs font-medium text-warm-300/60 uppercase tracking-wider">Infrastructure Health</p>
            <p class="mt-2 text-2xl font-bold text-grey-600 font-heading">--</p>
            <p class="mt-1 text-xs text-grey-600" title="Raspberry Pi CPU, memory and disk usage">Pi CPU / memory / disk</p>
          </div>
          <div class="p-4 bg-grey-800/50 rounded-xl border border-grey-700/50 border-dashed">
            <p class="text-xs font-medium text-warm-300/60 uppercase tracking-wider">Churn Signals</p>
            <p class="mt-2 text-2xl font-bold text-grey-600 font-heading">--</p>
            <p class="mt-1 text-xs text-grey-600">Users who have not returned</p>
          </div>
          <div class="p-4 bg-grey-800/50 rounded-xl border border-grey-700/50 border-dashed">
            <p class="text-xs font-medium text-warm-300/60 uppercase tracking-wider" title="Time to Value: average time from signup to first CV generation">Time to Value</p>
            <p class="mt-2 text-2xl font-bold text-grey-600 font-heading">--</p>
            <p class="mt-1 text-xs text-grey-600">Signup to first CV</p>
          </div>
          <div class="p-4 bg-grey-800/50 rounded-xl border border-grey-700/50 border-dashed">
            <p class="text-xs font-medium text-warm-300/60 uppercase tracking-wider" title="p95 Response Time: 95th percentile server response time">p95 Response Time</p>
            <p class="mt-2 text-2xl font-bold text-grey-600 font-heading">--</p>
            <p class="mt-1 text-xs text-grey-600">95th percentile latency</p>
          </div>
        </div>
      </section>

      {/* ── Tech Stack & Integrations (collapsible, side by side) ── */}
      <section class="mb-6 grid gap-3 grid-cols-1 lg:grid-cols-2">
        <details class="bg-grey-800 rounded-xl border border-grey-700">
          <summary class="px-4 py-3 text-xs font-medium text-warm-300 uppercase tracking-wider cursor-pointer hover:text-white transition-colors select-none">
            Tech Stack
          </summary>
          <div class="px-4 pb-3 space-y-1">
            {[
              ['Next.js 16', 'App Router, Turbopack'],
              ['Supabase', 'Postgres, Auth, Storage'],
              ['Tailwind CSS 4', 'Styling'],
              ['Puppeteer', 'PDF generation'],
              ['docx', 'Word export'],
              ['@anthropic-ai/sdk', 'Claude AI'],
              ['Vercel', 'Hosting (free tier)'],
            ].map(([tool, purpose]) => (
              <div class="flex items-center justify-between text-xs">
                <span class="text-white font-mono">{tool}</span>
                <span class="text-warm-300 truncate ml-2">{purpose}</span>
              </div>
            ))}
          </div>
        </details>

        <details class="bg-grey-800 rounded-xl border border-grey-700">
          <summary class="px-4 py-3 text-xs font-medium text-warm-300 uppercase tracking-wider cursor-pointer hover:text-white transition-colors select-none">
            Third-Party Integrations
          </summary>
          <div class="px-4 pb-3 space-y-1">
            {[
              ['Supabase', 'Database, auth, storage'],
              ['Vercel', 'Hosting, serverless'],
              ['Anthropic Claude', 'AI pipeline'],
              ['GoCardless', 'Payments'],
              ['Cloudflare', 'DNS, CDN'],
            ].map(([service, role]) => (
              <div class="flex items-center justify-between text-xs">
                <span class="text-white font-mono">{service}</span>
                <span class="text-warm-300 truncate ml-2">{role}</span>
              </div>
            ))}
          </div>
        </details>
      </section>
    </div>
  )}

  {/* ── smagile.co ── */}
  {activeTab === 'smagile-co' && (
    <div>
      <div class="mb-4">
        <h2 class="text-xl font-bold text-white font-heading">smagile.co</h2>
        <p class="mt-0.5 text-sm text-warm-300">Company website and Mission Control</p>
      </div>

      <div class="p-4 bg-grey-800 rounded-xl border border-grey-700 mb-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-secondary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <p class="text-sm font-medium text-white">Metrics coming soon</p>
            <p class="mt-1 text-xs text-warm-300">
              This project does not have Supabase or automated code health collection yet.
              Deployment monitoring and build metrics will be added in a future iteration.
            </p>
          </div>
        </div>
      </div>

      <div class="grid gap-3 grid-cols-2 lg:grid-cols-3">
        <StatCard label="Hosting" value="Raspberry Pi" subtitle="Behind Cloudflare tunnel" />
        <StatCard label="Framework" value="Astro 5" subtitle="SSR with @astrojs/node" />
        <StatCard label="Repository" value="GitHub" subtitle="AgileSmagile/smagilewebsite-v2" />
      </div>
    </div>
  )}

  {/* ── Agent Status (always visible below project content) ── */}
  <section class="mt-8 mb-8 pt-6 border-t border-grey-700">
    <div class="mb-3">
      <h2 class="text-xl font-bold text-white font-heading">Agent Status</h2>
      <p class="mt-0.5 text-sm text-warm-300">
        {onlineCount} of {totalAgentCount} agents online
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {agents.map((agent) => (
        <AgentCard agent={agent} />
      ))}
    </div>

    {agents.length === 0 && (
      <div class="text-center py-12">
        <p class="text-warm-300">No agents registered.</p>
      </div>
    )}
  </section>
</AdminLayout>
