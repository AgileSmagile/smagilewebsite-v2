---
import PublicLayout from '../../layouts/PublicLayout.astro';
---

<PublicLayout
  title="Recommended Reading"
  description="Books, podcasts, and learning resources recommended by Smagile for agile practitioners."
>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <h1 class="text-3xl sm:text-4xl font-bold text-grey-900 dark:text-white">
      Recommended Reading
    </h1>
    <p class="mt-4 text-lg text-grey-700 dark:text-grey-300">
      A curated collection of books, podcasts, and resources that have shaped our thinking
      and practice. We update this regularly.
    </p>

    <div class="mt-12 space-y-8">
      <div>
        <h2 class="text-xl font-semibold text-grey-900 dark:text-white mb-4">Books</h2>
        <p class="text-grey-700 dark:text-grey-300 italic">
          Reading list coming soon. Check back shortly.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-grey-900 dark:text-white mb-4">Podcasts</h2>
        <p class="text-grey-700 dark:text-grey-300 italic">
          Podcast recommendations coming soon. Check back shortly.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-grey-900 dark:text-white mb-4">
          Open Source and Tools
        </h2>
        <p class="text-grey-700 dark:text-grey-300 italic">
          Our open-source resources and tools will be listed here soon.
        </p>
      </div>
    </div>
  </section>
</PublicLayout>
