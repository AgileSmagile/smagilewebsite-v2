---
import PublicLayout from '../layouts/PublicLayout.astro';
import Hero from '../components/Hero.astro';
import ProblemCard from '../components/ProblemCard.astro';
import JsonLd from '../components/JsonLd.astro';

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'smagile',
  url: 'https://smagile.co',
  description:
    'Remote-first agile consultancy helping teams deliver better outcomes through practical support, training, and coaching.',
  founder: {
    '@type': 'Person',
    name: 'James Farley',
    jobTitle: 'Agile Consultant',
  },
  serviceType: ['Agile Consultancy', 'Agile Training', 'Facilitation', 'Coaching'],
  areaServed: 'GB',
  knowsAbout: ['Agile', 'Scrum', 'Kanban', 'ProKanban', 'Facilitation'],
};
---

<PublicLayout
  title="Home"
  description="smagile is a remote-first agile consultancy helping teams deliver better outcomes through practical support, training, and coaching."
>
  <JsonLd data={businessSchema} />
  <Hero
    headline="Better outcomes start with better ways of working"
    subtext="Remote-first agile consultancy helping teams deliver with clarity and purpose."
    ctaText="Book a free consultation"
    ctaHref="/contact/"
  />

  <!-- Problem-focused sections -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold text-grey-800 dark:text-white font-heading">
        Sound familiar?
      </h2>
      <div class="mt-4 mx-auto w-16 divider-gold"></div>
    </div>
    <div class="grid gap-6 sm:grid-cols-1 lg:grid-cols-3">
      <ProblemCard
        problem="Your teams are doing agile, but it doesn't feel like it's working"
        solution="We work alongside your teams to identify what is really getting in the way, and help them find a sustainable path forward."
        href="/how-we-help/consultancy/"
      />
      <ProblemCard
        problem="You need practical skills, not just certification"
        solution="Our training goes beyond theory. We focus on real-world application, giving your people skills they can use from day one."
        href="/how-we-help/training/prokanban/"
        linkText="Explore training"
      />
      <ProblemCard
        problem="You want hands-on support that adapts to your context, not a playbook"
        solution="Every organisation is different. We tailor our approach to your people, your culture, and your goals."
        href="/how-we-help/#about"
        linkText="Learn about our approach"
      />
    </div>
  </section>

  <!-- Values -->
  <section class="relative bg-primary dark:bg-grey-800 py-20 overflow-hidden">
    <!-- Subtle pattern overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/30 to-transparent"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-white font-heading">
          What we stand for
        </h2>
        <div class="mt-4 mx-auto w-16 h-px bg-gradient-to-r from-transparent via-accent-light to-transparent"></div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="text-center p-6 rounded-xl bg-white/10 backdrop-blur-sm">
          <h3 class="font-semibold text-accent-light font-heading">Neurodiversity</h3>
          <p class="mt-2 text-sm text-white/80">
            Fostering environments conducive to human neurodiversity, and being patient with change.
          </p>
        </div>
        <div class="text-center p-6 rounded-xl bg-white/10 backdrop-blur-sm">
          <h3 class="font-semibold text-accent-light font-heading">Integrity</h3>
          <p class="mt-2 text-sm text-white/80">
            The most reliable way to earn trust and respect.
          </p>
        </div>
        <div class="text-center p-6 rounded-xl bg-white/10 backdrop-blur-sm">
          <h3 class="font-semibold text-accent-light font-heading">Celebrating failure</h3>
          <p class="mt-2 text-sm text-white/80">
            Every failure is a learning opportunity. We create space for experimentation.
          </p>
        </div>
        <div class="text-center p-6 rounded-xl bg-white/10 backdrop-blur-sm">
          <h3 class="font-semibold text-accent-light font-heading">Speaking up</h3>
          <p class="mt-2 text-sm text-white/80">
            When something does not feel right, say so. Psychological safety is not optional.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center px-4">
    <h2 class="text-2xl sm:text-3xl font-bold text-grey-800 dark:text-white font-heading">
      Ready to talk?
    </h2>
    <div class="mt-4 mx-auto w-16 divider-gold"></div>
    <p class="mt-6 text-grey-700 dark:text-warm-300 max-w-xl mx-auto leading-relaxed">
      Book a free, no-obligation consultation call. We will listen to your challenges and discuss how we might help.
    </p>
    <div class="mt-8">
      <a
        href="/contact/"
        class="inline-block px-8 py-3.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-all shadow-lg shadow-primary/20 hover:shadow-primary/30 hover:-translate-y-0.5"
      >
        Get in touch
      </a>
    </div>
  </section>
</PublicLayout>
