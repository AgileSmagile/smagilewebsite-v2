---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <slot name="head" slot="head" />
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
    Skip to main content
  </a>
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />
  {import.meta.env.PUBLIC_GA_MEASUREMENT_ID && (
    <div data-ga-id={import.meta.env.PUBLIC_GA_MEASUREMENT_ID} hidden />
  )}
  <CookieConsent />
</BaseLayout>
