---
import BaseLayout from './BaseLayout.astro';
import AdminSidebar from '../components/admin/AdminSidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const userEmail = Astro.request.headers.get('Cf-Access-Authenticated-User-Email');
---

<BaseLayout title={title} darkDefault={true}>
  <!-- Top bar -->
  <header class="sticky top-0 z-50 bg-grey-900/90 backdrop-blur-sm border-b border-grey-700">
    <div class="flex items-center justify-between h-12 px-4">
      <div class="flex items-center gap-3">
        <button id="open-mobile-sidebar" class="p-1 text-warm-300 hover:text-white md:hidden" aria-label="Open menu">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <a href="/" class="text-secondary font-bold font-heading">smagile</a>
        <span class="text-xs font-mono text-accent-light bg-grey-800 px-2 py-0.5 rounded border border-grey-700">Admin</span>
      </div>
      <div class="flex items-center gap-3">
        {userEmail && <span class="hidden sm:inline text-xs text-grey-500">{userEmail}</span>}
        <a href="/" class="text-xs text-warm-300 hover:text-secondary transition-colors">View Site</a>
      </div>
    </div>
  </header>

  <!-- Sidebar + main content -->
  <div class="flex flex-1 min-h-0">
    <AdminSidebar currentPath={currentPath} />
    <main class="flex-1 overflow-y-auto px-4 sm:px-6 lg:px-8 py-6">
      <slot />
    </main>
  </div>

  <footer class="border-t border-grey-800 py-3 px-4">
    <div class="flex items-center justify-between text-xs text-grey-500">
      {userEmail ? (
        <span>Signed in as {userEmail}</span>
      ) : (
        <span>smagile admin</span>
      )}
      <span>&copy; {new Date().getFullYear()} smagile</span>
    </div>
  </footer>
</BaseLayout>
