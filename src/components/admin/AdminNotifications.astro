---
/**
 * Toast notification container for admin pages.
 * Include once in AdminLayout. Client-side JS can push notifications via:
 *
 *   window.adminNotify('Something went wrong', 'error');
 *   window.adminNotify('Saved successfully', 'success');
 *
 * Server-side pages can inject initial errors via the `errors` prop:
 *
 *   <AdminNotifications errors={['Supabase not reachable']} />
 */
interface Props {
  errors?: string[];
  warnings?: string[];
}

const { errors = [], warnings = [] } = Astro.props;
---

<div id="admin-notifications" class="fixed top-14 right-4 z-50 flex flex-col gap-2 max-w-sm" aria-live="polite">
</div>

<script define:vars={{ serverErrors: errors, serverWarnings: warnings }}>
  const container = document.getElementById('admin-notifications');

  function createToast(message, type) {
    const toast = document.createElement('div');
    toast.setAttribute('role', 'alert');

    const colours = {
      error: 'bg-red-900/90 border-red-500/50 text-red-200',
      warning: 'bg-amber-900/90 border-amber-500/50 text-amber-200',
      success: 'bg-green-900/90 border-green-500/50 text-green-200',
      info: 'bg-grey-800/90 border-grey-600 text-warm-200',
    };

    const icons = {
      error: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z',
      warning: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z',
      success: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
      info: 'M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z',
    };

    toast.className = `flex items-start gap-2 px-4 py-3 rounded-lg border text-sm backdrop-blur-sm shadow-lg animate-slide-in ${colours[type] || colours.info}`;

    const iconSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    iconSvg.setAttribute('class', 'w-5 h-5 shrink-0 mt-0.5');
    iconSvg.setAttribute('fill', 'none');
    iconSvg.setAttribute('viewBox', '0 0 24 24');
    iconSvg.setAttribute('stroke', 'currentColor');
    iconSvg.setAttribute('stroke-width', '1.5');
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('stroke-linecap', 'round');
    path.setAttribute('stroke-linejoin', 'round');
    path.setAttribute('d', icons[type] || icons.info);
    iconSvg.appendChild(path);
    toast.appendChild(iconSvg);

    const text = document.createElement('span');
    text.textContent = message;
    toast.appendChild(text);

    const closeBtn = document.createElement('button');
    closeBtn.className = 'ml-auto p-0.5 opacity-60 hover:opacity-100 transition-opacity';
    closeBtn.setAttribute('aria-label', 'Dismiss');
    closeBtn.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>';
    closeBtn.addEventListener('click', () => toast.remove());
    toast.appendChild(closeBtn);

    container.appendChild(toast);

    // Auto-dismiss after 8 seconds (errors stay longer at 15s)
    const duration = type === 'error' ? 15000 : 8000;
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(100%)';
      toast.style.transition = 'opacity 300ms, transform 300ms';
      setTimeout(() => toast.remove(), 300);
    }, duration);
  }

  // Expose globally for admin pages
  window.adminNotify = createToast;

  // Show server-side errors on load
  serverErrors.forEach(msg => createToast(msg, 'error'));
  serverWarnings.forEach(msg => createToast(msg, 'warning'));
</script>

<style>
  @keyframes slide-in {
    from { opacity: 0; transform: translateX(100%); }
    to { opacity: 1; transform: translateX(0); }
  }
  .animate-slide-in {
    animation: slide-in 200ms ease-out;
  }
</style>
