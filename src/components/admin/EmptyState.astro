---
interface Props {
  /** Main heading text */
  heading: string;
  /** Supporting description text */
  message: string;
  /** Optional SVG path data for the icon (uses 24x24 heroicon viewBox) */
  iconPath?: string;
}

const { heading, message, iconPath } = Astro.props;
---

<div class="bg-grey-800 rounded-xl border border-grey-700 p-12 text-center">
  {iconPath && (
    <svg class="w-12 h-12 text-grey-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
    </svg>
  )}
  <h2 class="text-lg font-semibold text-white mb-2">{heading}</h2>
  <p class="text-sm text-grey-500">{message}</p>
</div>
