---
---

<footer class="mt-auto bg-secondary-50 dark:bg-grey-800 border-t border-secondary-200 dark:border-grey-700">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-start justify-between gap-6">
      <!-- Quick links (left) -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a href="/how-we-help/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">How We Help</a>
        <a href="/products/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Products</a>
        <a href="/resources/blog/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Blog</a>
        <a href="/partnership/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Partners</a>
        <a href="/contact/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Contact</a>
      </div>

      <!-- Social + Legal (right) -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <a href="https://www.linkedin.com/company/smagile" target="_blank" rel="noopener noreferrer" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors" aria-label="smagile on LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://github.com/AgileSmagile" target="_blank" rel="noopener noreferrer" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors" aria-label="smagile on GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
        </a>
        <span class="text-secondary-200 dark:text-grey-600">|</span>
        <a href="/privacy/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Privacy Policy</a>
        <button id="cookie-preferences-btn" type="button" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors cursor-pointer">Cookie Preferences</button>
      </div>
    </div>

    <div class="mt-6 pt-6 border-t border-secondary-200 dark:border-grey-700 text-xs text-grey-500 dark:text-warm-300 flex items-center justify-between">
      <p>&copy; 2021&ndash;{new Date().getFullYear()} smagile. All rights reserved.</p>
      <a href="/admin/" class="text-warm-300 dark:text-grey-500 hover:text-primary dark:hover:text-secondary transition-colors" aria-label="Admin login">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cookie-preferences-btn')?.addEventListener('click', () => {
    localStorage.removeItem('cookie-consent');
    const banner = document.getElementById('cookie-consent');
    banner?.classList.remove('hidden');
  });
</script>
