---
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto bg-grey-50 dark:bg-grey-800 border-t border-grey-200 dark:border-grey-700">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-primary dark:text-secondary font-bold text-lg">Smagile</p>
        <p class="mt-2 text-sm text-grey-700 dark:text-grey-300">
          Remote-first agile consultancy helping teams deliver better outcomes.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-semibold text-grey-800 dark:text-grey-100 mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/how-we-help/" class="text-grey-700 dark:text-grey-300 hover:text-primary dark:hover:text-secondary transition-colors">How We Help</a></li>
          <li><a href="/resources/blog/" class="text-grey-700 dark:text-grey-300 hover:text-primary dark:hover:text-secondary transition-colors">Blog</a></li>
          <li><a href="/about/" class="text-grey-700 dark:text-grey-300 hover:text-primary dark:hover:text-secondary transition-colors">About</a></li>
          <li><a href="/contact/" class="text-grey-700 dark:text-grey-300 hover:text-primary dark:hover:text-secondary transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-grey-800 dark:text-grey-100 mb-3">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy/" class="text-grey-700 dark:text-grey-300 hover:text-primary dark:hover:text-secondary transition-colors">Privacy Policy</a></li>
          <li><button id="cookie-preferences-btn" type="button" class="text-grey-700 dark:text-grey-300 hover:text-primary dark:hover:text-secondary transition-colors cursor-pointer">Cookie Preferences</button></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-grey-200 dark:border-grey-700 text-sm text-grey-700 dark:text-grey-300">
      <p>&copy; {currentYear} Smagile. All rights reserved.</p>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cookie-preferences-btn')?.addEventListener('click', () => {
    localStorage.removeItem('cookie-consent');
    const banner = document.getElementById('cookie-consent');
    banner?.classList.remove('hidden');
  });
</script>
