---
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto bg-secondary-50 dark:bg-grey-800 border-t border-secondary-200 dark:border-grey-700">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-primary dark:text-secondary font-bold text-lg font-heading">smagile</p>
        <p class="mt-2 text-sm text-grey-700 dark:text-warm-200">
          Remote-first agile consultancy helping teams deliver better outcomes.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-semibold text-grey-800 dark:text-warm-100 mb-3 font-heading">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/how-we-help/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">How We Help</a></li>
          <li><a href="/resources/blog/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Blog</a></li>
          <li><a href="/about/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">About</a></li>
          <li><a href="/contact/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-grey-800 dark:text-warm-100 mb-3 font-heading">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Privacy Policy</a></li>
          <li><button id="cookie-preferences-btn" type="button" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors cursor-pointer">Cookie Preferences</button></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-secondary-200 dark:border-grey-700 text-sm text-grey-700 dark:text-warm-300 flex items-center justify-between">
      <p>&copy; {currentYear} smagile. All rights reserved.</p>
      <a href="/admin/" class="text-warm-300 dark:text-grey-500 hover:text-primary dark:hover:text-secondary transition-colors" aria-label="Admin login">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cookie-preferences-btn')?.addEventListener('click', () => {
    localStorage.removeItem('cookie-consent');
    const banner = document.getElementById('cookie-consent');
    banner?.classList.remove('hidden');
  });
</script>
