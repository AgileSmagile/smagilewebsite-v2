---

<footer class="mt-auto bg-secondary-50 dark:bg-grey-800 border-t border-secondary-200 dark:border-grey-700">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-start justify-between gap-6">
      <!-- Quick links (left) -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a href="/how-we-help/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">How We Help</a>
        <a href="/resources/blog/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Blog</a>
        <a href="/about/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">About</a>
        <a href="/contact/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Contact</a>
      </div>

      <!-- Legal (right) -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a href="/privacy/" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors">Privacy Policy</a>
        <button id="cookie-preferences-btn" type="button" class="text-grey-700 dark:text-warm-200 hover:text-primary dark:hover:text-secondary transition-colors cursor-pointer">Cookie Preferences</button>
      </div>
    </div>

    <div class="mt-6 pt-6 border-t border-secondary-200 dark:border-grey-700 text-xs text-grey-500 dark:text-warm-300 flex items-center justify-between">
      <p>&copy; 2021&ndash;{new Date().getFullYear()} smagile. All rights reserved.</p>
      <a href="/admin/" class="text-warm-300 dark:text-grey-500 hover:text-primary dark:hover:text-secondary transition-colors" aria-label="Admin login">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cookie-preferences-btn')?.addEventListener('click', () => {
    localStorage.removeItem('cookie-consent');
    const banner = document.getElementById('cookie-consent');
    banner?.classList.remove('hidden');
  });
</script>
