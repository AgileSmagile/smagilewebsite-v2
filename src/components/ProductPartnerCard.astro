---
interface Props {
  name: string;
  tagline: string;
  description: string;
  href: string;
}

const { name, tagline, description, href } = Astro.props;
---

<div class="group relative p-6 sm:p-8 bg-secondary-50 dark:bg-grey-800 rounded-xl border border-secondary-200 dark:border-grey-700 hover:border-accent/40 dark:hover:border-secondary/40 transition-all hover:shadow-lg hover:shadow-accent/5">
  <!-- Gold accent bar -->
  <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-accent-light/60 to-transparent"></div>

  <div class="flex items-start gap-5">
    <!-- Partner logo: TODO -->
    <div class="shrink-0 w-12 h-12 rounded-lg bg-secondary-100 dark:bg-grey-700 flex items-center justify-center">
      <span class="text-lg font-bold text-primary dark:text-secondary font-heading">{name.charAt(0)}</span>
    </div>
    <div class="min-w-0">
      <h3 class="text-lg font-semibold text-grey-800 dark:text-white font-heading">{name}</h3>
      <p class="mt-1 text-sm text-accent dark:text-accent-light font-medium">{tagline}</p>
    </div>
  </div>

  <p class="mt-4 text-grey-700 dark:text-warm-300 leading-relaxed">{description}</p>

  <a
    href={href}
    rel="noopener sponsored"
    target="_blank"
    class="mt-5 inline-flex items-center gap-1.5 text-primary dark:text-secondary font-medium group-hover:gap-2.5 transition-all"
  >
    Visit {name}
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
    </svg>
  </a>
</div>
