---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  {
    label: 'How We Help',
    href: '/how-we-help/',
    children: [
      { label: 'Consultancy and Facilitation', href: '/how-we-help/consultancy/' },
      { label: 'ProKanban Training', href: '/how-we-help/training/prokanban/' },
      { label: 'Agile Fundamentals', href: '/how-we-help/training/agile-fundamentals/' },
    ],
  },
  { label: 'Products', href: '/products/' },
  {
    label: 'Resources',
    href: '/resources/',
    children: [
      { label: 'Blog', href: '/resources/blog/' },
      { label: 'Recommended Reading', href: '/resources/reading/' },
      { label: 'Open Source & Tools', href: '/resources/reading/#open-source' },
    ],
  },
  { label: 'Partners', href: '/partnership/' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-secondary-50/95 dark:bg-grey-900/95 backdrop-blur-sm border-b border-secondary-200/60 dark:border-grey-800">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl font-heading tracking-tight">
        <span class="text-primary dark:text-secondary">smagile</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  'px-3 py-2 rounded-lg text-sm font-medium transition-colors inline-flex items-center gap-1',
                  isActive(item.href)
                    ? 'text-primary dark:text-secondary bg-secondary-100 dark:bg-grey-800'
                    : 'text-grey-700 dark:text-warm-100 hover:text-primary dark:hover:text-secondary hover:bg-secondary-100 dark:hover:bg-grey-800',
                ]}
              >
                {item.label}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div class="absolute left-0 top-full pt-1 hidden group-hover:block">
                <div class="bg-white dark:bg-grey-800 rounded-lg shadow-lg border border-secondary-200 dark:border-grey-700 py-1 min-w-[220px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        isActive(child.href)
                          ? 'text-primary dark:text-secondary bg-secondary-100 dark:bg-grey-700'
                          : 'text-grey-700 dark:text-warm-100 hover:text-primary dark:hover:text-secondary hover:bg-secondary-100 dark:hover:bg-grey-700',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'text-primary dark:text-secondary bg-secondary-100 dark:bg-grey-800'
                  : 'text-grey-700 dark:text-warm-100 hover:text-primary dark:hover:text-secondary hover:bg-secondary-100 dark:hover:bg-grey-800',
              ]}
            >
              {item.label}
            </a>
          )
        ))}
        <ThemeToggle />
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          class="p-2 rounded-lg hover:bg-secondary-100 dark:hover:bg-grey-800 transition-colors"
        >
          <svg class="w-6 h-6 text-grey-700 dark:text-warm-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'text-primary dark:text-secondary bg-secondary-100 dark:bg-grey-800'
                : 'text-grey-700 dark:text-warm-100 hover:text-primary dark:hover:text-secondary',
            ]}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="ml-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block px-3 py-2 rounded-lg text-sm transition-colors',
                    isActive(child.href)
                      ? 'text-primary dark:text-secondary bg-secondary-100 dark:bg-grey-700'
                      : 'text-grey-700 dark:text-warm-100 hover:text-primary dark:hover:text-secondary',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
